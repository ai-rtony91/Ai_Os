{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "OPENAI_PLANNER_OUTPUT.schema.json",
  "title": "AI_OS OpenAI Planner Output Fixture Schema",
  "type": "object",
  "required": [
    "fixture_id",
    "fixture_type",
    "mode",
    "autonomy_level",
    "classification",
    "packet_preview",
    "requires_human_approval",
    "live_trading_status",
    "broker_execution_status",
    "secret_handling_status",
    "validator_chain",
    "stop_point",
    "recommended_next_action"
  ],
  "properties": {
    "fixture_id": {
      "type": "string"
    },
    "fixture_type": {
      "const": "openai_planner_output"
    },
    "mode": {
      "type": "string",
      "enum": [
        "FIXTURE_ONLY",
        "DRY_RUN_ONLY"
      ]
    },
    "autonomy_level": {
      "type": "string"
    },
    "classification": {
      "type": "object",
      "required": [
        "safety_status",
        "approval_status",
        "blocked_actions_detected",
        "blocked_reason"
      ],
      "properties": {
        "safety_status": {
          "type": "string"
        },
        "approval_status": {
          "type": "string"
        },
        "blocked_actions_detected": {
          "type": "boolean"
        },
        "blocked_reason": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "packet_preview": {
      "type": "object",
      "required": [
        "identity_marker",
        "execution_token_required",
        "packet_id",
        "mode",
        "zone",
        "worker_identity",
        "lane",
        "branch",
        "worktree",
        "objective",
        "allowed_paths",
        "forbidden_paths",
        "approval_authority",
        "validator_chain",
        "stop_point"
      ],
      "properties": {
        "identity_marker": {
          "type": "string"
        },
        "execution_token_required": {
          "type": "boolean"
        },
        "packet_id": {
          "type": "string"
        },
        "mode": {
          "type": "string"
        },
        "zone": {
          "type": "string"
        },
        "worker_identity": {
          "type": "string"
        },
        "lane": {
          "type": "string"
        },
        "branch": {
          "type": "string"
        },
        "worktree": {
          "type": "string"
        },
        "objective": {
          "type": "string"
        },
        "allowed_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "forbidden_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "approval_authority": {
          "type": "string"
        },
        "validator_chain": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "stop_point": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "requires_human_approval": {
      "type": "boolean"
    },
    "live_trading_status": {
      "type": "string",
      "enum": [
        "BLOCKED",
        "PAPER_ONLY"
      ]
    },
    "broker_execution_status": {
      "type": "string",
      "enum": [
        "BLOCKED"
      ]
    },
    "secret_handling_status": {
      "type": "string",
      "enum": [
        "BLOCKED_NO_SECRETS_ALLOWED"
      ]
    },
    "validator_chain": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "stop_point": {
      "type": "string"
    },
    "recommended_next_action": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
