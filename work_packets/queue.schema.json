{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "AIOS_WORK_QUEUE.v1",
  "title": "AI_OS Persistent Work Queue",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "queue_id",
    "version",
    "created_at",
    "updated_at",
    "mode",
    "queue_status",
    "packets",
    "lanes",
    "approvals",
    "validators",
    "next_action",
    "stop_condition"
  ],
  "properties": {
    "queue_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": [
        "DRY_RUN",
        "APPLY"
      ]
    },
    "queue_status": {
      "type": "string",
      "enum": [
        "pending",
        "active",
        "blocked",
        "complete"
      ]
    },
    "packets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "packet_id",
          "source_file",
          "title",
          "lane",
          "status",
          "priority",
          "approval_state",
          "validator_state",
          "assigned_worker",
          "blocked_reason",
          "next_action"
        ],
        "properties": {
          "packet_id": {
            "type": "string",
            "minLength": 1
          },
          "source_file": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "lane": {
            "type": "string",
            "enum": [
              "main_control",
              "build_engine",
              "validation",
              "docs",
              "dashboard",
              "operator_review"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "approved",
              "dispatched",
              "validating",
              "blocked",
              "complete"
            ]
          },
          "priority": {
            "type": "integer",
            "minimum": 1
          },
          "approval_state": {
            "type": "string",
            "enum": [
              "not_requested",
              "requested",
              "approved",
              "rejected"
            ]
          },
          "validator_state": {
            "type": "string",
            "enum": [
              "not_run",
              "pass",
              "fail",
              "warning"
            ]
          },
          "assigned_worker": {
            "type": "string"
          },
          "blocked_reason": {
            "type": "string"
          },
          "next_action": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "lanes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "lane",
          "role",
          "status",
          "current_packet"
        ],
        "properties": {
          "lane": {
            "type": "string",
            "enum": [
              "main_control",
              "build_engine",
              "validation",
              "docs",
              "dashboard",
              "operator_review"
            ]
          },
          "role": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "minLength": 1
          },
          "current_packet": {
            "type": "string"
          }
        }
      }
    },
    "approvals": {
      "type": "object"
    },
    "validators": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "next_action": {
      "type": "string",
      "minLength": 1
    },
    "stop_condition": {
      "type": "string",
      "minLength": 1
    }
  }
}
