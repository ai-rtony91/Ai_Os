{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "AIOS_WORK_PACKET.v1",
  "title": "AI_OS Work Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "title",
    "lane",
    "mode",
    "status",
    "objective",
    "allowed_actions",
    "blocked_actions",
    "files_in_scope",
    "validators",
    "risks",
    "stop_condition",
    "approval_required",
    "created_by",
    "notes"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "lane": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": [
        "DRY_RUN",
        "APPLY"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "READY_FOR_DRY_RUN",
        "READY_FOR_APPLY",
        "BLOCKED",
        "REVIEW"
      ]
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "allowed_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "blocked_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "files_in_scope": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "validators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "risks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "stop_condition": {
      "type": "string",
      "minLength": 1
    },
    "approval_required": {
      "type": "boolean"
    },
    "created_by": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
