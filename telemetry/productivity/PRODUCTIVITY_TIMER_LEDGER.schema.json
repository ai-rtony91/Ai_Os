{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aios.local/schemas/productivity/PRODUCTIVITY_TIMER_LEDGER.schema.json",
  "title": "AI_OS Productivity Timer Ledger Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "session_id",
    "date_key",
    "operator_start_time",
    "operator_stop_time",
    "elapsed_minutes",
    "active_packet_id",
    "worker_lane",
    "task_label",
    "validator_started_at",
    "validator_finished_at",
    "validator_elapsed_seconds",
    "output_summary",
    "blocked_reason",
    "evidence_ready_for_collect"
  ],
  "properties": {
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "date_key": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "operator_start_time": {
      "type": "string",
      "format": "date-time"
    },
    "operator_stop_time": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "elapsed_minutes": {
      "type": ["number", "null"],
      "minimum": 0
    },
    "active_packet_id": {
      "type": "string"
    },
    "worker_lane": {
      "type": "string"
    },
    "task_label": {
      "type": "string"
    },
    "validator_started_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "validator_finished_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "validator_elapsed_seconds": {
      "type": ["number", "null"],
      "minimum": 0
    },
    "output_summary": {
      "type": "string"
    },
    "blocked_reason": {
      "type": ["string", "null"]
    },
    "evidence_ready_for_collect": {
      "type": "boolean"
    }
  }
}
