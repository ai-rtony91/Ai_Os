{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/orchestration/aios_autonomy_decision_governor.schema.json",
  "title": "AI_OS Autonomy Decision Governor Decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "system",
    "component",
    "mode",
    "decision_id",
    "generated_at_utc",
    "next_highest_value_task",
    "decision_category",
    "why_this_task",
    "risk_level",
    "allowed_lane",
    "required_validators",
    "stop_conditions",
    "blocked",
    "blocked_reason",
    "evidence_inputs",
    "safety_boundaries",
    "confidence",
    "recommended_packet_scope",
    "ranked_candidates",
    "selected_candidate_id",
    "selection_reason"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "system": { "const": "AI_OS" },
    "component": { "const": "autonomy_decision_governor" },
    "mode": { "const": "APPLY_SAFE_DECISION_OUTPUT" },
    "decision_id": { "type": "string", "minLength": 1 },
    "generated_at_utc": { "type": "string", "minLength": 1 },
    "next_highest_value_task": { "type": "string", "minLength": 1 },
    "decision_category": {
      "type": "string",
      "enum": [
        "STATUS_RECON",
        "VALIDATOR_REPAIR",
        "QUEUE_CONSOLIDATION",
        "APPROVAL_GATE_REPAIR",
        "SELF_BUILD_LOOP_WIRING",
        "TRADING_LAB_PAPER_ONLY_IMPROVEMENT",
        "DASHBOARD_SURFACING",
        "TELEMETRY_REPORTING",
        "BLOCKED_STOP_AND_REPORT"
      ]
    },
    "why_this_task": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "blocked"]
    },
    "allowed_lane": {
      "type": "string",
      "enum": [
        "READ_ONLY",
        "DRY_RUN",
        "APPLY_DOCS_ONLY",
        "APPLY_TESTS_ONLY",
        "APPLY_CODE_SAFE",
        "BLOCKED"
      ]
    },
    "required_validators": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "stop_conditions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "blocked": { "type": "boolean" },
    "blocked_reason": {
      "anyOf": [
        { "type": "null" },
        { "type": "string", "minLength": 1 }
      ]
    },
    "evidence_inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "status", "summary"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "status": {
            "type": "string",
            "enum": ["present", "missing", "unknown"]
          },
          "summary": { "type": "string" }
        }
      }
    },
    "safety_boundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "live_trading",
        "broker_execution",
        "credential_use",
        "unapproved_mutation"
      ],
      "properties": {
        "live_trading": { "const": "blocked" },
        "broker_execution": { "const": "blocked" },
        "credential_use": { "const": "blocked" },
        "unapproved_mutation": { "const": "blocked" }
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "recommended_packet_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packet_id_suggestion",
        "mode",
        "lane",
        "files_allowed",
        "files_forbidden"
      ],
      "properties": {
        "packet_id_suggestion": { "type": "string", "minLength": 1 },
        "mode": { "type": "string", "enum": ["DRY_RUN", "APPLY"] },
        "lane": { "type": "string", "minLength": 1 },
        "files_allowed": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "files_forbidden": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "ranked_candidates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "task_id",
          "title",
          "category",
          "value_score",
          "urgency_score",
          "risk_score",
          "blocker_score",
          "validation_score",
          "autonomy_leverage_score",
          "total_score",
          "reason",
          "required_validator",
          "allowed_lane",
          "stop_condition",
          "blocked"
        ],
        "properties": {
          "task_id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "category": { "type": "string", "enum": [
            "STATUS_RECON",
            "VALIDATOR_REPAIR",
            "QUEUE_CONSOLIDATION",
            "APPROVAL_GATE_REPAIR",
            "SELF_BUILD_LOOP_WIRING",
            "TRADING_LAB_PAPER_ONLY_IMPROVEMENT",
            "DASHBOARD_SURFACING",
            "TELEMETRY_REPORTING",
            "BLOCKED_STOP_AND_REPORT"
          ] },
          "value_score": { "type": "integer", "minimum": 0 },
          "urgency_score": { "type": "integer", "minimum": 0 },
          "risk_score": { "type": "integer", "minimum": 0 },
          "blocker_score": { "type": "integer", "minimum": 0 },
          "validation_score": { "type": "integer", "minimum": 0 },
          "autonomy_leverage_score": { "type": "integer", "minimum": 0 },
          "total_score": { "type": "integer", "minimum": 0 },
          "reason": { "type": "string", "minLength": 1 },
          "required_validator": { "type": "string", "minLength": 1 },
          "allowed_lane": {
            "type": "string",
            "enum": [
              "READ_ONLY",
              "DRY_RUN",
              "APPLY_DOCS_ONLY",
              "APPLY_TESTS_ONLY",
              "APPLY_CODE_SAFE",
              "BLOCKED"
            ]
          },
          "stop_condition": { "type": "string", "minLength": 1 },
          "blocked": { "type": "boolean" }
        }
      }
    },
    "selected_candidate_id": {
      "type": "string",
      "minLength": 1
    },
    "selection_reason": {
      "type": "string",
      "minLength": 1
    }
  }
}
