{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/orchestration/aios_closed_loop_queue_injection_preview.schema.json",
  "title": "AI_OS Closed Loop Queue Injection Preview",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "system",
    "component",
    "mode",
    "generated_at_utc",
    "input_status",
    "proposed_queue_item",
    "validation",
    "safety_boundaries",
    "next_step"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "system": { "const": "AI_OS" },
    "component": { "const": "closed_loop_queue_injection_preview" },
    "mode": { "const": "APPLY_BUILD_WITH_QUEUE_PREVIEW_OUTPUT" },
    "generated_at_utc": { "type": "string", "minLength": 1 },
    "input_status": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packet_drafter_preview", "packet_blueprint"],
      "properties": {
        "packet_drafter_preview": {
          "type": "string",
          "enum": ["present", "missing", "blocked"]
        },
        "packet_blueprint": {
          "type": "string",
          "enum": ["present", "missing", "invalid"]
        }
      }
    },
    "proposed_queue_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "queue_item_id",
        "source_component",
        "source_preview_path",
        "packet_id",
        "mode",
        "lane",
        "risk_level",
        "approval_required",
        "approval_authority",
        "validators_required",
        "allowed_paths",
        "forbidden_paths",
        "stop_conditions",
        "dispatch_authorized",
        "queue_mutation_authorized",
        "status",
        "blocked_reason"
      ],
      "properties": {
        "queue_item_id": { "type": "string", "minLength": 1 },
        "source_component": { "const": "closed_loop_packet_drafter" },
        "source_preview_path": {
          "const": "Reports/sandbox/closed_loop_packet_drafter/AIOS_CLOSED_LOOP_PACKET_DRAFTER_PREVIEW.json"
        },
        "packet_id": { "type": "string", "minLength": 1 },
        "mode": { "type": "string", "minLength": 1 },
        "lane": { "type": "string", "minLength": 1 },
        "risk_level": { "type": "string", "minLength": 1 },
        "approval_required": { "type": "boolean" },
        "approval_authority": { "const": "Anthony Meza" },
        "validators_required": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "allowed_paths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "forbidden_paths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "stop_conditions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "dispatch_authorized": { "const": false },
        "queue_mutation_authorized": { "const": false },
        "status": {
          "type": "string",
          "enum": ["preview_only", "blocked", "requires_approval"]
        },
        "blocked_reason": {
          "anyOf": [
            { "type": "null" },
            { "type": "string" }
          ]
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required_fields_present", "missing_fields", "blocked", "blocked_reason"],
      "properties": {
        "required_fields_present": { "type": "boolean" },
        "missing_fields": {
          "type": "array",
          "items": { "type": "string" }
        },
        "blocked": { "type": "boolean" },
        "blocked_reason": {
          "anyOf": [
            { "type": "null" },
            { "type": "string" }
          ]
        }
      }
    },
    "safety_boundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "real_queue_mutation",
        "worker_dispatch",
        "continuous_loop",
        "live_trading",
        "broker_execution",
        "credential_use",
        "unapproved_mutation"
      ],
      "properties": {
        "real_queue_mutation": { "const": "blocked" },
        "worker_dispatch": { "const": "blocked" },
        "continuous_loop": { "const": "blocked" },
        "live_trading": { "const": "blocked" },
        "broker_execution": { "const": "blocked" },
        "credential_use": { "const": "blocked" },
        "unapproved_mutation": { "const": "blocked" }
      }
    },
    "next_step": { "type": "string", "minLength": 1 }
  }
}
