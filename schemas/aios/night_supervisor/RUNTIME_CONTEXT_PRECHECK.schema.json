{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI_OS Runtime Context Precheck",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "precheck_id",
    "mode",
    "local_fixture_only",
    "expected_userprofile_check",
    "pwd_check_required",
    "git_root_check_required",
    "expected_worktree_check_required",
    "python_path_cwd_check_required",
    "canonical_profile_check_required",
    "active_lock_check_required",
    "dirty_tree_check_required",
    "forbidden_path_dirty_check_required",
    "mode_check_required",
    "known_failure",
    "night_supervisor_runtime_start_allowed",
    "human_approval_required",
    "fail_closed",
    "stop_point"
  ],
  "properties": {
    "precheck_id": { "type": "string" },
    "mode": { "type": "string", "const": "DRY_RUN" },
    "local_fixture_only": { "type": "boolean", "const": true },
    "expected_userprofile_check": { "type": "boolean", "const": true },
    "pwd_check_required": { "type": "boolean", "const": true },
    "git_root_check_required": { "type": "boolean", "const": true },
    "expected_worktree_check_required": { "type": "boolean", "const": true },
    "python_path_cwd_check_required": { "type": "boolean", "const": true },
    "canonical_profile_check_required": { "type": "boolean", "const": true },
    "active_lock_check_required": { "type": "boolean", "const": true },
    "dirty_tree_check_required": { "type": "boolean", "const": true },
    "forbidden_path_dirty_check_required": { "type": "boolean", "const": true },
    "mode_check_required": { "type": "boolean", "const": true },
    "known_failure": { "type": "string" },
    "night_supervisor_runtime_start_allowed": { "type": "boolean", "const": false },
    "human_approval_required": { "type": "boolean", "const": true },
    "fail_closed": { "type": "boolean", "const": true },
    "stop_point": { "type": "string" }
  }
}
