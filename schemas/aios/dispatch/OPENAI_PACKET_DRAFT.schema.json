{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI_OS OpenAI Packet Draft",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "packet_id",
    "mode",
    "local_fixture_only",
    "live_openai_api_call",
    "api_key_required",
    "network_required",
    "package_install_required",
    "repo_mutation_allowed",
    "requested_route",
    "allowed_paths",
    "forbidden_paths",
    "human_approval_required",
    "commit_allowed",
    "push_allowed",
    "merge_allowed",
    "live_trading_status",
    "broker_execution_status",
    "oanda_status",
    "pi_gpio_motor_status",
    "profitability_priority",
    "fail_closed",
    "stop_point"
  ],
  "properties": {
    "packet_id": { "type": "string" },
    "mode": { "type": "string", "const": "DRY_RUN" },
    "local_fixture_only": { "type": "boolean", "const": true },
    "live_openai_api_call": { "type": "boolean", "const": false },
    "api_key_required": { "type": "boolean", "const": false },
    "network_required": { "type": "boolean", "const": false },
    "package_install_required": { "type": "boolean", "const": false },
    "repo_mutation_allowed": { "type": "boolean", "const": false },
    "requested_route": { "type": "string" },
    "allowed_paths": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "forbidden_paths": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "human_approval_required": { "type": "boolean", "const": true },
    "commit_allowed": { "type": "boolean", "const": false },
    "push_allowed": { "type": "boolean", "const": false },
    "merge_allowed": { "type": "boolean", "const": false },
    "live_trading_status": { "type": "string", "const": "BLOCKED" },
    "broker_execution_status": { "type": "string", "const": "BLOCKED" },
    "oanda_status": { "type": "string", "const": "BLOCKED" },
    "pi_gpio_motor_status": { "type": "string", "const": "BLOCKED" },
    "profitability_priority": { "type": "string", "const": "TRUSTED_PROVEN_PROFITABILITY" },
    "fail_closed": { "type": "boolean", "const": true },
    "stop_point": { "type": "string" }
  }
}
