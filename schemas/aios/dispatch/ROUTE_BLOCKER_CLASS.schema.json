{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI_OS Route Blocker Class",
  "type": "object",
  "additionalProperties": false,
  "required": ["blocker_class", "severity", "blocks_execution", "requires_human_approval", "fail_closed", "stop_point"],
  "properties": {
    "blocker_class": { "type": "string" },
    "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
    "blocks_execution": { "type": "boolean" },
    "requires_human_approval": { "type": "boolean" },
    "fail_closed": { "type": "boolean" },
    "stop_point": { "type": "string" }
  }
}

