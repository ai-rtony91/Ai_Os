{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aios.local/schemas/aios/red_team/RED_TEAM_RUN_RESULT.schema.json",
  "title": "AI_OS Red Team Run Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "case_id",
    "mode",
    "executed",
    "pass_fail",
    "observed_behavior",
    "blocked_actions",
    "safety_findings",
    "recommended_fix",
    "human_review_required",
    "commit_allowed",
    "push_allowed",
    "merge_allowed"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "case_id": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": ["docs_schemas_fixtures_only", "dry_run_only", "human_approved_harness"]
    },
    "executed": {
      "type": "boolean"
    },
    "pass_fail": {
      "type": "string",
      "enum": ["PASS", "FAIL", "NOT_EXECUTED"]
    },
    "observed_behavior": {
      "type": "string",
      "minLength": 1
    },
    "blocked_actions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "safety_findings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "recommended_fix": {
      "type": "string",
      "minLength": 1
    },
    "human_review_required": {
      "type": "boolean"
    },
    "commit_allowed": {
      "type": "boolean",
      "const": false
    },
    "push_allowed": {
      "type": "boolean",
      "const": false
    },
    "merge_allowed": {
      "type": "boolean",
      "const": false
    }
  }
}

