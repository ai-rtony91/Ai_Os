{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/aios/runtime/AIOS_APPROVAL_PAUSE_STATE.schema.json",
  "title": "AI_OS Approval Pause State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "mode",
    "local_fixture_only",
    "approval_state",
    "approval_scope",
    "requested_action",
    "validator_evidence",
    "resume_from_state",
    "state_strategy",
    "human_approval_required",
    "trusted_proven_profitability_priority",
    "commit_allowed",
    "push_allowed",
    "merge_allowed",
    "broker_execution_status",
    "oanda_status",
    "live_trading_status",
    "secrets_allowed",
    "fail_closed"
  ],
  "properties": {
    "run_id": { "type": "string" },
    "mode": { "type": "string", "enum": ["DRY_RUN"] },
    "local_fixture_only": { "type": "boolean", "const": true },
    "approval_state": { "type": "string", "enum": ["approval_requested", "approval_pending", "approval_granted", "approval_rejected", "resumed_from_state", "parked_by_human", "expired"] },
    "approval_scope": { "type": "string" },
    "requested_action": { "type": "string" },
    "validator_evidence": { "type": "array", "items": { "type": "string" } },
    "resume_from_state": { "type": "string" },
    "state_strategy": { "type": "string", "enum": ["local_replay_state", "session_state", "previous_response_id", "conversation_id"] },
    "human_approval_required": { "type": "boolean", "const": true },
    "trusted_proven_profitability_priority": { "type": "boolean", "const": true },
    "commit_allowed": { "type": "boolean", "const": false },
    "push_allowed": { "type": "boolean", "const": false },
    "merge_allowed": { "type": "boolean", "const": false },
    "broker_execution_status": { "type": "string", "const": "BLOCKED" },
    "oanda_status": { "type": "string", "const": "BLOCKED" },
    "live_trading_status": { "type": "string", "const": "BLOCKED" },
    "secrets_allowed": { "type": "boolean", "const": false },
    "fail_closed": { "type": "boolean", "const": true }
  }
}

