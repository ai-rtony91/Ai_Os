{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/aios/runtime/AIOS_RUN_STATE.schema.json",
  "title": "AI_OS Run State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "mode",
    "local_fixture_only",
    "state_strategy",
    "current_stage",
    "lifecycle",
    "manager_owner",
    "handoff_active",
    "approval_state",
    "trusted_proven_profitability_priority",
    "paper_only_trading",
    "broker_execution_status",
    "oanda_status",
    "live_trading_status",
    "secrets_allowed",
    "uncontrolled_autonomy_allowed",
    "pi_gpio_motor_status",
    "night_supervisor_runtime_start_allowed",
    "final_report_required",
    "paste_back_summary_required",
    "clean_state_result_required",
    "fail_closed"
  ],
  "properties": {
    "run_id": { "type": "string" },
    "mode": { "type": "string", "enum": ["DRY_RUN"] },
    "local_fixture_only": { "type": "boolean", "const": true },
    "state_strategy": { "type": "string", "enum": ["local_replay_state", "session_state", "previous_response_id", "conversation_id"] },
    "current_stage": { "type": "string" },
    "lifecycle": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "manager_owner": { "type": "string", "const": "AI_OS_MANAGER" },
    "handoff_active": { "type": "boolean" },
    "approval_state": { "type": "string" },
    "trusted_proven_profitability_priority": { "type": "boolean", "const": true },
    "paper_only_trading": { "type": "boolean", "const": true },
    "broker_execution_status": { "type": "string", "const": "BLOCKED" },
    "oanda_status": { "type": "string", "const": "BLOCKED" },
    "live_trading_status": { "type": "string", "const": "BLOCKED" },
    "secrets_allowed": { "type": "boolean", "const": false },
    "uncontrolled_autonomy_allowed": { "type": "boolean", "const": false },
    "pi_gpio_motor_status": { "type": "string", "const": "BLOCKED" },
    "night_supervisor_runtime_start_allowed": { "type": "boolean", "const": false },
    "final_report_required": { "type": "boolean", "const": true },
    "paste_back_summary_required": { "type": "boolean", "const": true },
    "clean_state_result_required": { "type": "boolean", "const": true },
    "fail_closed": { "type": "boolean", "const": true }
  }
}

