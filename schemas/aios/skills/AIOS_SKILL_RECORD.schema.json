{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI_OS Skill Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "skill_id",
    "version",
    "status",
    "workflow",
    "local_first",
    "hosted_allowed",
    "risk_class",
    "allowed_paths",
    "forbidden_paths",
    "requires_review",
    "requires_human_approval",
    "bypasses_agents_md",
    "bypasses_approval_gates",
    "secrets_allowed",
    "env_file_creation_allowed",
    "network_allowed",
    "shell_execution_allowed",
    "skill_upload_allowed",
    "skill_execution_allowed",
    "live_trading_status",
    "broker_execution_status",
    "oanda_status",
    "pi_gpio_motor_status",
    "night_supervisor_runtime_modification_allowed",
    "stop_point"
  ],
  "properties": {
    "skill_id": { "type": "string" },
    "version": { "type": "string" },
    "status": { "type": "string", "enum": ["PROPOSED", "REVIEWED", "APPROVED_LOCAL_ONLY", "BLOCKED", "RETIRED"] },
    "workflow": { "type": "string" },
    "local_first": { "type": "boolean", "const": true },
    "hosted_allowed": { "type": "boolean", "const": false },
    "risk_class": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "BLOCKED"] },
    "allowed_paths": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "forbidden_paths": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "requires_review": { "type": "boolean", "const": true },
    "requires_human_approval": { "type": "boolean", "const": true },
    "bypasses_agents_md": { "type": "boolean", "const": false },
    "bypasses_approval_gates": { "type": "boolean", "const": false },
    "secrets_allowed": { "type": "boolean", "const": false },
    "env_file_creation_allowed": { "type": "boolean", "const": false },
    "network_allowed": { "type": "boolean", "const": false },
    "shell_execution_allowed": { "type": "boolean", "const": false },
    "skill_upload_allowed": { "type": "boolean", "const": false },
    "skill_execution_allowed": { "type": "boolean", "const": false },
    "live_trading_status": { "type": "string", "const": "BLOCKED" },
    "broker_execution_status": { "type": "string", "const": "BLOCKED" },
    "oanda_status": { "type": "string", "const": "BLOCKED" },
    "pi_gpio_motor_status": { "type": "string", "const": "BLOCKED" },
    "night_supervisor_runtime_modification_allowed": { "type": "boolean", "const": false },
    "stop_point": { "type": "string" }
  }
}
