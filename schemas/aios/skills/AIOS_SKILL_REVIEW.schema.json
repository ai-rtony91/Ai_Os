{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI_OS Skill Review",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "review_id",
    "skill_id",
    "review_status",
    "reviewer_role",
    "workflow_fit",
    "manifest_present",
    "versioned",
    "allowed_paths_validated",
    "forbidden_paths_validated",
    "agents_md_compliance",
    "approval_gate_compliance",
    "secret_safety",
    "network_safety",
    "shell_safety",
    "skill_upload_allowed",
    "skill_execution_allowed",
    "broker_trading_safety",
    "pi_gpio_motor_safety",
    "night_supervisor_runtime_safety",
    "required_evidence",
    "recommended_next_action"
  ],
  "properties": {
    "review_id": { "type": "string" },
    "skill_id": { "type": "string" },
    "review_status": { "type": "string", "enum": ["PASS", "FAIL", "BLOCKED", "PREVIEW_ONLY"] },
    "reviewer_role": { "type": "string" },
    "workflow_fit": { "type": "boolean" },
    "manifest_present": { "type": "boolean" },
    "versioned": { "type": "boolean" },
    "allowed_paths_validated": { "type": "boolean" },
    "forbidden_paths_validated": { "type": "boolean" },
    "agents_md_compliance": { "type": "boolean" },
    "approval_gate_compliance": { "type": "boolean" },
    "secret_safety": { "type": "boolean" },
    "network_safety": { "type": "boolean" },
    "shell_safety": { "type": "boolean" },
    "skill_upload_allowed": { "type": "boolean", "const": false },
    "skill_execution_allowed": { "type": "boolean", "const": false },
    "broker_trading_safety": { "type": "string", "const": "BLOCKED" },
    "pi_gpio_motor_safety": { "type": "string", "const": "BLOCKED" },
    "night_supervisor_runtime_safety": { "type": "string", "const": "BLOCKED" },
    "required_evidence": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "recommended_next_action": { "type": "string" }
  }
}
