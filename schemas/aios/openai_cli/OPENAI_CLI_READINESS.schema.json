{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/aios/openai_cli/OPENAI_CLI_READINESS.schema.json",
  "title": "AI_OS OpenAI CLI Readiness",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "mode",
    "local_fixture_only",
    "openai_cli_detected",
    "openai_api_key_env_detected",
    "api_key_value_printed",
    "forbidden_secret_files_present",
    "live_openai_api_call",
    "admin_api_used",
    "service_account_created",
    "env_file_created",
    "network_required",
    "package_install_required",
    "repo_mutation_allowed",
    "human_approval_required",
    "fail_closed",
    "profitability_priority",
    "stop_point"
  ],
  "properties": {
    "schema": { "type": "string", "const": "aios.openai_cli_readiness.v1" },
    "mode": { "type": "string", "enum": ["DRY_RUN"] },
    "local_fixture_only": { "type": "boolean", "const": true },
    "openai_cli_detected": { "type": "boolean" },
    "openai_api_key_env_detected": { "type": "boolean" },
    "api_key_value_printed": { "type": "boolean", "const": false },
    "forbidden_secret_files_present": { "type": "array", "items": { "type": "string" } },
    "live_openai_api_call": { "type": "boolean", "const": false },
    "admin_api_used": { "type": "boolean", "const": false },
    "service_account_created": { "type": "boolean", "const": false },
    "env_file_created": { "type": "boolean", "const": false },
    "network_required": { "type": "boolean", "const": false },
    "package_install_required": { "type": "boolean", "const": false },
    "repo_mutation_allowed": { "type": "boolean", "const": false },
    "human_approval_required": { "type": "boolean", "const": true },
    "fail_closed": { "type": "boolean", "const": true },
    "profitability_priority": { "type": "string", "const": "TRUSTED_PROVEN_PROFITABILITY" },
    "stop_point": { "type": "string" }
  }
}

