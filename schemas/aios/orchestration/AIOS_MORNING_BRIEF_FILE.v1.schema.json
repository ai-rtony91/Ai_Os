  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "AIOS_MORNING_BRIEF_FILE.v1"
    },
    "generated_at": {
      "type": "string"
    },
    "supervisor_status": {
      "type": "string"
    },
    "packet_flow": {
      "type": "array"
    },
    "escalation_items": {
      "type": "array"
    }
  }
}
