{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-os.local/schemas/aios/orchestration/LOCK_REGISTRY_SCHEMA.v0.1.1",
  "title": "AI_OS Lock Registry Schema",
  "description": "v0.1.1 JSON Schema for AI_OS file and path lock records. Supports registry-wrapper and single-lock-record shapes. Contract scaffold only; it does not claim, release, or override locks.",
  "type": "object",
  "additionalProperties": true,
  "oneOf": [
    {
      "required": [
        "lock_registry_id",
        "locks"
      ],
      "properties": {
        "lock_registry_id": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "locks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/lock_record"
          }
        }
      }
    },
    {
      "$ref": "#/$defs/lock_record"
    }
  ],
  "$defs": {
    "lock_record": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "lock_id",
        "status"
      ],
      "properties": {
        "schema": {
          "type": "string"
        },
        "lock_id": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string"
        },
        "worker_id": {
          "type": "string"
        },
        "packet_id": {
          "type": "string"
        },
        "lane": {
          "type": "string"
        },
        "paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "locked_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "lock_reason": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "minLength": 1
        },
        "conflict_policy": {
          "type": "string"
        },
        "blocked_if_locked": {
          "type": "boolean"
        },
        "next_action": {
          "type": "string"
        },
        "expires_at": {
          "type": "string"
        },
        "created_at": {
          "type": "string"
        },
        "released_at": {
          "type": "string"
        },
        "updated_at": {
          "type": "string"
        }
      }
    }
  }
}
