{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-os.local/schemas/aios/orchestration/RUNTIME_VISIBILITY_SCHEMA.v0.1.2",
  "title": "AI_OS Runtime Visibility Read Model Schema",
  "description": "v0.1.2 JSON Schema for AI_OS runtime API and dashboard visibility read models. Supports current API and mock shapes. Visibility projections are evidence and display data, not command authority.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema",
    "frontend_contract",
    "source_paths"
  ],
  "properties": {
    "schema": {
      "type": "string"
    },
    "projection_id": {
      "type": "string"
    },
    "schema_version": {
      "type": "string"
    },
    "generatedAt": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "mode": {
      "type": "string"
    },
    "frontend_contract": {
      "$ref": "#/$defs/frontend_contract"
    },
    "projection_items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/frontend_contract"
      }
    },
    "source_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": true
    },
    "health": {
      "type": "object",
      "additionalProperties": true
    },
    "queue": {
      "type": "object",
      "additionalProperties": true
    },
    "workers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "activePackets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "failedPackets": {
      "type": "object",
      "additionalProperties": true
    },
    "packets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "approvals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "validators": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "locks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": true
    },
    "controls": {
      "type": "object",
      "additionalProperties": true
    },
    "backpressure": {
      "type": "object",
      "additionalProperties": true
    },
    "alerts": {
      "type": "array",
      "items": {
        "type": [
          "string",
          "object"
        ]
      }
    },
    "telemetry": {
      "type": "object",
      "additionalProperties": true
    },
    "executionLedger": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": true
        },
        {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        }
      ]
    },
    "overall_status": {
      "type": "string"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": [
          "string",
          "object"
        ]
      }
    },
    "nextSafeAction": {
      "type": "string"
    },
    "next_safe_action": {
      "type": "string"
    }
  },
  "$defs": {
    "freshness": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "checked_at": {
          "type": "string"
        },
        "generated_at": {
          "type": "string"
        },
        "ttl_seconds": {
          "type": "integer",
          "minimum": 0
        },
        "is_stale": {
          "type": "boolean"
        }
      }
    },
    "frontend_contract": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "display_state",
        "authority_state",
        "source_path",
        "source_type",
        "freshness",
        "blocked_actions",
        "next_safe_action",
        "approval_required",
        "execution_allowed",
        "mutation_allowed",
        "stale_or_legacy",
        "safe_for_frontend_display"
      ],
      "properties": {
        "display_state": {
          "type": "string"
        },
        "authority_state": {
          "type": "string",
          "enum": [
            "CANONICAL_AUTHORITY",
            "EVIDENCE_ONLY",
            "DISPLAY_ONLY",
            "LEGACY_REFERENCE",
            "NON_CANONICAL",
            "UNKNOWN"
          ]
        },
        "source_path": {
          "type": "string"
        },
        "source_type": {
          "type": "string"
        },
        "freshness": {
          "$ref": "#/$defs/freshness"
        },
        "blocked_actions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "next_safe_action": {
          "type": "string"
        },
        "approval_required": {
          "type": "boolean"
        },
        "execution_allowed": {
          "type": "boolean",
          "const": false
        },
        "mutation_allowed": {
          "type": "boolean",
          "const": false
        },
        "stale_or_legacy": {
          "type": "boolean"
        },
        "safe_for_frontend_display": {
          "type": "boolean"
        }
      }
    }
  }
}
