{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aios.local/schemas/orchestration/overnight_supervisor.schema.json",
  "title": "AI_OS Overnight Supervisor Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "supervisor_status",
    "repo_health",
    "stale_packets",
    "packet_flow",
    "validator_recommendations",
    "validator_results",
    "approval_required",
    "commit_package_candidates",
    "escalation_items",
    "next_safe_actions",
    "packet_drafts",
    "morning_brief",
    "generated_at",
    "mode",
    "authority_boundary"
  ],
  "properties": {
    "supervisor_status": {
      "type": "string",
      "enum": ["READY", "REVIEW", "WARNING", "BLOCKED", "UNKNOWN"]
    },
    "repo_health": {
      "type": "object",
      "additionalProperties": false,
      "required": ["branch", "status_summary", "changed_files", "untracked_items", "risk_level"],
      "properties": {
        "branch": { "type": "string" },
        "status_summary": { "type": "string" },
        "changed_files": {
          "type": "array",
          "items": { "type": "string" }
        },
        "untracked_items": {
          "type": "array",
          "items": { "type": "string" }
        },
        "risk_level": {
          "type": "string",
          "enum": ["SAFE", "WATCH", "WARNING", "BLOCKED", "UNKNOWN"]
        }
      }
    },
    "stale_packets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["packet_id", "state", "reason", "next_safe_action"],
        "properties": {
          "packet_id": { "type": "string" },
          "state": { "type": "string" },
          "reason": { "type": "string" },
          "next_safe_action": { "type": "string" }
        }
      }
    },
    "packet_flow": {
      "type": "array",
      "description": "Read-only packet intake, worker resolution, validator, approval, stop-condition, and reporting summary.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "packet_id",
          "lane",
          "worker_identity",
          "validator_chain",
          "approval_required",
          "escalation_reason",
          "stop_condition",
          "packet_state",
          "report_target",
          "commit_package_candidate",
          "next_safe_action"
        ],
        "properties": {
          "packet_id": { "type": "string" },
          "lane": { "type": "string" },
          "worker_identity": { "type": "string" },
          "validator_chain": {
            "type": "array",
            "items": { "type": "string" }
          },
          "approval_required": { "type": "boolean" },
          "escalation_reason": { "type": "string" },
          "stop_condition": { "type": "string" },
          "packet_state": {
            "type": "string",
            "enum": [
              "READY_FOR_REVIEW",
              "VALIDATOR_REQUIRED",
              "APPROVAL_REQUIRED",
              "COMMIT_PACKAGE_CANDIDATE",
              "BLOCKED",
              "STALE",
              "UNKNOWN"
            ]
          },
          "report_target": { "type": "string" },
          "commit_package_candidate": { "type": "boolean" },
          "next_safe_action": { "type": "string" }
        }
      }
    },
    "validator_recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["validator_id", "priority", "reason", "next_safe_action"],
        "properties": {
          "validator_id": { "type": "string" },
          "priority": {
            "type": "string",
            "enum": ["LOW", "MEDIUM", "HIGH", "BLOCKING"]
          },
          "reason": { "type": "string" },
          "next_safe_action": { "type": "string" }
        }
      }
    },
    "validator_results": {
      "type": "array",
      "description": "Read-only summary of validator state evidence when available.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["validator_id", "state", "evidence", "next_safe_action"],
        "properties": {
          "validator_id": { "type": "string" },
          "state": {
            "type": "string",
            "enum": ["PASS", "WARN", "FAIL", "BLOCKED", "UNKNOWN", "NOT_RUN"]
          },
          "evidence": { "type": "string" },
          "next_safe_action": { "type": "string" }
        }
      }
    },
    "approval_required": {
      "type": "array",
      "description": "Packets or actions that require Human Owner approval before mutation or protected action.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["packet_id", "reason", "approval_authority", "next_safe_action"],
        "properties": {
          "packet_id": { "type": "string" },
          "reason": { "type": "string" },
          "approval_authority": { "type": "string" },
          "next_safe_action": { "type": "string" }
        }
      }
    },
    "commit_package_candidates": {
      "type": "array",
      "description": "Exact-file commit package candidates only; this does not authorize staging, commit, push, PR creation, or merge.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["packet_id", "lane", "candidate_files", "status", "next_safe_action"],
        "properties": {
          "packet_id": { "type": "string" },
          "lane": { "type": "string" },
          "candidate_files": {
            "type": "array",
            "items": { "type": "string" }
          },
          "status": {
            "type": "string",
            "enum": ["READY_FOR_REVIEW", "NEEDS_VALIDATION", "NEEDS_APPROVAL", "BLOCKED", "UNKNOWN"]
          },
          "next_safe_action": { "type": "string" }
        }
      }
    },
    "escalation_items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "trigger", "evidence", "next_safe_action"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["REVIEW", "WARNING", "BLOCKED"]
          },
          "trigger": { "type": "string" },
          "evidence": { "type": "string" },
          "next_safe_action": { "type": "string" }
        }
      }
    },
    "next_safe_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["rank", "action", "requires_human_approval", "blocked_actions"],
        "properties": {
          "rank": { "type": "integer", "minimum": 1 },
          "action": { "type": "string" },
          "requires_human_approval": { "type": "boolean" },
          "blocked_actions": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "packet_drafts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "lane", "mode", "allowed_paths", "forbidden_paths", "stop_point"],
        "properties": {
          "title": { "type": "string" },
          "lane": { "type": "string" },
          "mode": {
            "type": "string",
            "enum": ["DRY_RUN", "APPLY_PROPOSAL_ONLY"]
          },
          "allowed_paths": {
            "type": "array",
            "items": { "type": "string" }
          },
          "forbidden_paths": {
            "type": "array",
            "items": { "type": "string" }
          },
          "stop_point": { "type": "string" }
        }
      }
    },
    "morning_brief": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "blockers", "approval_needed", "review_items", "recommended_first_action", "safe_to_ignore", "today_focus"],
      "properties": {
        "summary": { "type": "string" },
        "blockers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "approval_needed": { "type": "boolean" },
        "review_items": {
          "type": "array",
          "items": { "type": "string" }
        },
        "recommended_first_action": { "type": "string" },
        "safe_to_ignore": {
          "type": "array",
          "items": { "type": "string" }
        },
        "today_focus": { "type": "string" }
      }
    },
    "generated_at": {
      "type": "string",
      "description": "ISO-like timestamp generated by the report producer."
    },
    "mode": {
      "type": "string",
      "const": "DRY_RUN"
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["read_only", "approval_authority", "blocked_capabilities"],
      "properties": {
        "read_only": { "type": "boolean", "const": true },
        "approval_authority": { "type": "string" },
        "blocked_capabilities": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      }
    }
  }
}
