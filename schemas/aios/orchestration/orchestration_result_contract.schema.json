{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aios.local/schemas/orchestration/orchestration_result_contract.schema.json",
  "title": "AI_OS Orchestration Result Contract",
  "description": "Canonical read-only result shape for validator chains, approval summaries, commit-package planners, recommendation systems, and Overnight Supervisor consumption. Contract only; it does not authorize APPLY, packet movement, staging, commit, push, merge, worker launch, broker execution, live trading, secret handling, or credential access.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "severity",
    "packet_id",
    "worker_identity",
    "validator_results",
    "approval_required",
    "blocked_reason",
    "escalation_reason",
    "commit_candidate",
    "next_safe_action",
    "stop_condition",
    "runtime_notes",
    "evidence",
    "generated_at"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["PASS", "READY", "REVIEW", "WARN", "FAIL", "BLOCKED", "UNKNOWN", "NOT_RUN"]
    },
    "severity": {
      "type": "string",
      "enum": ["INFO", "REVIEW", "WARNING", "BLOCKER", "BLOCKED", "UNKNOWN"]
    },
    "packet_id": {
      "type": "string",
      "minLength": 1
    },
    "worker_identity": {
      "type": "string",
      "minLength": 1
    },
    "validator_results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["validator_id", "status", "severity", "evidence"],
        "properties": {
          "validator_id": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["PASS", "WARN", "FAIL", "BLOCKED", "UNKNOWN", "NOT_RUN"]
          },
          "severity": {
            "type": "string",
            "enum": ["INFO", "REVIEW", "REVIEW_REQUIRED", "WARNING", "BLOCKER", "BLOCKED", "UNKNOWN"]
          },
          "evidence": { "type": "string" },
          "next_safe_action": { "type": "string" }
        }
      }
    },
    "approval_required": {
      "type": "boolean"
    },
    "blocked_reason": {
      "type": "string"
    },
    "escalation_reason": {
      "type": "string"
    },
    "commit_candidate": {
      "type": "boolean"
    },
    "next_safe_action": {
      "type": "string",
      "minLength": 1
    },
    "stop_condition": {
      "type": "string",
      "minLength": 1
    },
    "runtime_notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": true,
      "description": "Source-specific read-only evidence. This object may contain existing validator, approval, commit-package, recommendation, git, schema, or supervisor fields without changing their native contracts."
    },
    "generated_at": {
      "type": "string",
      "description": "UTC or ISO-like timestamp generated by the reporting producer."
    }
  }
}
