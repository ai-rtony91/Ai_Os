{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aios.local/schemas/orchestration/AIOS_FULL_AUTONOMY_WORKER_LAUNCH_PREFLIGHT_GATE_RESULT.v1.schema.json",
  "title": "AIOS Full Autonomy Worker Launch Preflight Gate Result v1",
  "description": "Console-only read-only worker launch preflight gate result. This schema grants no worker launch, APPLY, approval, queue, lock, relay, runtime, scheduler, broker, trading, commit, push, PR, or merge authority.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema",
    "mode",
    "generated_utc",
    "repo_state",
    "requested_autonomy_level",
    "operating_profile",
    "requested_worker_posture",
    "input_evidence",
    "preflight_decision",
    "worker_launch_allowed_for_future_step",
    "worker_launch_executed",
    "worker_posture",
    "recommended_worker_count",
    "max_parallel_workers",
    "allowed_worker_lanes",
    "blocked_worker_lanes",
    "human_wake_policy",
    "approval_required",
    "missing_requirements",
    "protected_actions",
    "recommended_validators",
    "safety",
    "no_write_proof",
    "stop_conditions",
    "next_safe_action"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "AIOS_FULL_AUTONOMY_WORKER_LAUNCH_PREFLIGHT_GATE_RESULT.v1"
    },
    "mode": {
      "type": "string",
      "const": "DRY_RUN_READ_ONLY"
    },
    "generated_utc": {
      "type": "string"
    },
    "repo_state": {
      "type": "object",
      "additionalProperties": true
    },
    "requested_autonomy_level": {
      "type": "string"
    },
    "operating_profile": {
      "type": "string"
    },
    "requested_worker_posture": {
      "type": "string",
      "enum": [
        "NO_WORKERS",
        "READ_ONLY_VALIDATOR_CREW",
        "PACKET_PREVIEW_CREW",
        "SUPERVISED_DAY_CREW_12H",
        "SUPERVISED_DAY_NIGHT_CREW_24H",
        "WEEKEND_LOW_TOUCH_CREW",
        "VACATION_EMERGENCY_ONLY_CREW",
        "FULL_AUTONOMY_SUPERVISED_CREW"
      ]
    },
    "input_evidence": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "human_owner_worker_launch_approval_present",
        "identity_spine_status",
        "validator_chain_status",
        "approval_sos_status",
        "governed_soak_status",
        "activation_gate_status",
        "worker_posture_bridge_status",
        "lock_collision_status",
        "allowed_lanes",
        "requested_worker_count",
        "requested_max_parallel_workers"
      ],
      "properties": {
        "human_owner_worker_launch_approval_present": {
          "type": "boolean"
        }
      }
    },
    "preflight_decision": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "decision",
        "worker_launch_allowed_for_future_step",
        "worker_launch_executed",
        "reason"
      ],
      "properties": {
        "decision": {
          "type": "string",
          "enum": [
            "DENIED",
            "REVIEW_REQUIRED",
            "PREFLIGHT_PASS_ADVISORY_ONLY",
            "PREFLIGHT_PASS_AWAITING_HUMAN_APPROVAL",
            "PREFLIGHT_PASS_WORKER_LAUNCH_ELIGIBLE_BUT_NOT_EXECUTED",
            "BLOCKED_BY_SOS",
            "BLOCKED_BY_APPROVAL",
            "BLOCKED_BY_IDENTITY",
            "BLOCKED_BY_VALIDATORS",
            "BLOCKED_BY_LOCK_COLLISION",
            "BLOCKED_BY_EMPTY_ALLOWED_LANES",
            "BLOCKED_BY_PROTECTED_LANE",
            "BLOCKED_BY_REPO_STATE",
            "BLOCKED_BY_SECRETS_OR_BROKER_BOUNDARY"
          ]
        },
        "worker_launch_executed": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "worker_launch_allowed_for_future_step": {
      "type": "boolean"
    },
    "worker_launch_executed": {
      "type": "boolean",
      "const": false
    },
    "worker_posture": {
      "type": "string"
    },
    "recommended_worker_count": {
      "type": "integer",
      "minimum": 0
    },
    "max_parallel_workers": {
      "type": "integer",
      "minimum": 0
    },
    "allowed_worker_lanes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blocked_worker_lanes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "human_wake_policy": {
      "type": "object",
      "additionalProperties": true
    },
    "approval_required": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "human_owner_required",
        "human_owner_worker_launch_approval_present",
        "required_before_worker_launch",
        "required_before_runtime_scheduler_or_daemon",
        "validator_pass_is_not_approval",
        "self_approval_allowed"
      ],
      "properties": {
        "human_owner_required": {
          "type": "boolean",
          "const": true
        },
        "required_before_worker_launch": {
          "type": "boolean",
          "const": true
        },
        "required_before_runtime_scheduler_or_daemon": {
          "type": "boolean",
          "const": true
        },
        "validator_pass_is_not_approval": {
          "type": "boolean",
          "const": true
        },
        "self_approval_allowed": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "missing_requirements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "protected_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "recommended_validators": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "status",
        "console_only",
        "writes_files",
        "writes_reports",
        "writes_telemetry",
        "creates_ready_stage",
        "mutates_registry",
        "mutates_queue",
        "mutates_locks",
        "mutates_approval",
        "mutates_approvals",
        "writes_relay",
        "starts_runtime",
        "launches_workers",
        "enables_scheduler",
        "starts_daemon",
        "touches_secrets_or_env",
        "secrets_or_env_access",
        "broker_or_live_trading",
        "protected_actions_blocked",
        "human_owner_required_before_worker_launch",
        "worker_launch_executed",
        "self_approval_allowed"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "PASS",
            "REVIEW_REQUIRED",
            "BLOCKED",
            "BLOCKED_BY_WRITE_SURFACE_RISK"
          ]
        },
        "console_only": {
          "type": "boolean",
          "const": true
        },
        "writes_files": {
          "type": "boolean",
          "const": false
        },
        "writes_reports": {
          "type": "boolean",
          "const": false
        },
        "writes_telemetry": {
          "type": "boolean",
          "const": false
        },
        "creates_ready_stage": {
          "type": "boolean",
          "const": false
        },
        "mutates_registry": {
          "type": "boolean",
          "const": false
        },
        "mutates_queue": {
          "type": "boolean",
          "const": false
        },
        "mutates_locks": {
          "type": "boolean",
          "const": false
        },
        "mutates_approval": {
          "type": "boolean",
          "const": false
        },
        "mutates_approvals": {
          "type": "boolean",
          "const": false
        },
        "writes_relay": {
          "type": "boolean",
          "const": false
        },
        "starts_runtime": {
          "type": "boolean",
          "const": false
        },
        "launches_workers": {
          "type": "boolean",
          "const": false
        },
        "enables_scheduler": {
          "type": "boolean",
          "const": false
        },
        "starts_daemon": {
          "type": "boolean",
          "const": false
        },
        "touches_secrets_or_env": {
          "type": "boolean",
          "const": false
        },
        "secrets_or_env_access": {
          "type": "boolean",
          "const": false
        },
        "broker_or_live_trading": {
          "type": "boolean",
          "const": false
        },
        "protected_actions_blocked": {
          "type": "boolean",
          "const": true
        },
        "human_owner_required_before_worker_launch": {
          "type": "boolean",
          "const": true
        },
        "worker_launch_executed": {
          "type": "boolean",
          "const": false
        },
        "self_approval_allowed": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "no_write_proof": {
      "type": "object",
      "additionalProperties": true
    },
    "stop_conditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_safe_action": {
      "type": "string"
    }
  }
}
