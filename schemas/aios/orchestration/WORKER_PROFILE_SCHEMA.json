{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-os.local/schemas/aios/orchestration/WORKER_PROFILE_SCHEMA.v0.1",
  "title": "AI_OS Worker Profile Schema",
  "description": "v0.1 JSON Schema for AI_OS worker profile and capability records. Contract scaffold only; it does not grant authority, create workers, or execute work.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "profile_id",
    "worker_id",
    "capabilities"
  ],
  "properties": {
    "profile_id": {
      "type": "string",
      "minLength": 1
    },
    "worker_id": {
      "type": "string",
      "minLength": 1
    },
    "display_name": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "zone": {
      "type": "string"
    },
    "lane": {
      "type": "string"
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "allowed_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blocked_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "allowed_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blocked_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "approval_required": {
      "type": "boolean"
    },
    "notes": {
      "type": "string"
    }
  }
}
