{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aios.local/schemas/orchestration/runtime_state_bundle.schema.json",
  "title": "AI_OS Runtime State Bundle",
  "description": "Read-only runtime aggregation contract for AI_OS orchestration evidence. This schema describes generated evidence only and does not grant mutation authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "schema_version",
    "generated_at",
    "mode",
    "authority_boundary",
    "frontend_contract",
    "packet_state",
    "worker_state",
    "lock_state",
    "validator_state",
    "approval_state",
    "escalation_state",
    "git_state",
    "supervisor_state",
    "next_safe_actions",
    "stale_conditions",
    "confidence_state",
    "validator_confidence",
    "auto_git_eligibility",
    "blocking_signals",
    "human_required_signals",
    "source_freshness",
    "bundle_integrity",
    "required_evidence_present"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "AIOS_RUNTIME_STATE_BUNDLE.v1"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "generated_at": {
      "type": "string",
      "description": "ISO-like timestamp when this read-only bundle was generated."
    },
    "mode": {
      "type": "string",
      "const": "DRY_RUN"
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "read_only",
        "approval_authority",
        "generated_evidence_only",
        "blocked_capabilities"
      ],
      "properties": {
        "read_only": {
          "type": "boolean",
          "const": true
        },
        "approval_authority": {
          "type": "string"
        },
        "generated_evidence_only": {
          "type": "boolean",
          "const": true
        },
        "blocked_capabilities": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "frontend_contract": {
      "$ref": "#/$defs/frontend_contract"
    },
    "packet_state": {
      "$ref": "#/$defs/runtime_section"
    },
    "worker_state": {
      "$ref": "#/$defs/runtime_section"
    },
    "lock_state": {
      "$ref": "#/$defs/runtime_section"
    },
    "validator_state": {
      "$ref": "#/$defs/runtime_section"
    },
    "approval_state": {
      "$ref": "#/$defs/runtime_section"
    },
    "escalation_state": {
      "$ref": "#/$defs/runtime_section"
    },
    "git_state": {
      "$ref": "#/$defs/runtime_section"
    },
    "supervisor_state": {
      "$ref": "#/$defs/runtime_section"
    },
    "next_safe_actions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/next_safe_action"
      }
    },
    "stale_conditions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stale_condition"
      }
    },
    "confidence_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "overall_confidence",
        "confidence_score",
        "confidence_reasons"
      ],
      "properties": {
        "overall_confidence": {
          "type": "string",
          "enum": [
            "HIGH",
            "MEDIUM",
            "LOW",
            "BLOCKED",
            "UNKNOWN"
          ]
        },
        "confidence_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "confidence_reasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "validator_confidence": {
      "$ref": "#/$defs/validator_confidence"
    },
    "auto_git_eligibility": {
      "$ref": "#/$defs/auto_git_eligibility"
    },
    "blocking_signals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "human_required_signals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_freshness": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/source_freshness_item"
      }
    },
    "bundle_integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "parse_errors",
        "missing_sources"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "PASS",
            "REVIEW",
            "BLOCKED"
          ]
        },
        "parse_errors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "missing_sources": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "required_evidence_present": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "validator_config",
        "validator_confidence",
        "git_state",
        "lock_registry",
        "approval_evidence",
        "packet_evidence"
      ],
      "properties": {
        "validator_config": {
          "type": "boolean"
        },
        "validator_confidence": {
          "type": "boolean"
        },
        "git_state": {
          "type": "boolean"
        },
        "lock_registry": {
          "type": "boolean"
        },
        "approval_evidence": {
          "type": "boolean"
        },
        "packet_evidence": {
          "type": "boolean"
        }
      }
    }
  },
  "$defs": {
    "validator_confidence": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "overall_result",
        "confidence_score",
        "confidence_band",
        "safe_auto_allowed_eligible"
      ],
      "properties": {
        "overall_result": {
          "type": "string"
        },
        "confidence_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "confidence_band": {
          "type": "string"
        },
        "safe_auto_allowed_eligible": {
          "type": "boolean"
        }
      }
    },
    "auto_git_eligibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "safe_auto_allowed",
        "minimum_confidence_score",
        "eligible_actions",
        "blocked_actions",
        "stop_conditions"
      ],
      "properties": {
        "safe_auto_allowed": {
          "type": "boolean"
        },
        "minimum_confidence_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "eligible_actions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blocked_actions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "stop_conditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "source_freshness_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "checked_at",
        "is_present",
        "is_stale"
      ],
      "properties": {
        "source": {
          "type": "string"
        },
        "checked_at": {
          "type": "string"
        },
        "is_present": {
          "type": "boolean"
        },
        "is_stale": {
          "type": "boolean"
        }
      }
    },
    "runtime_section": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "frontend_contract",
        "source_paths",
        "summary",
        "items",
        "freshness",
        "blocked_actions"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "READY",
            "REVIEW",
            "WARNING",
            "BLOCKED",
            "UNKNOWN"
          ]
        },
        "frontend_contract": {
          "$ref": "#/$defs/frontend_contract"
        },
        "source_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "summary": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "freshness": {
          "$ref": "#/$defs/freshness"
        },
        "blocked_actions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checked_at",
        "ttl_seconds",
        "is_stale"
      ],
      "properties": {
        "checked_at": {
          "type": "string"
        },
        "ttl_seconds": {
          "type": "integer",
          "minimum": 0
        },
        "is_stale": {
          "type": "boolean"
        }
      }
    },
    "frontend_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "display_state",
        "authority_state",
        "source_path",
        "source_type",
        "freshness",
        "blocked_actions",
        "next_safe_action",
        "approval_required",
        "execution_allowed",
        "mutation_allowed",
        "stale_or_legacy",
        "safe_for_frontend_display"
      ],
      "properties": {
        "display_state": {
          "type": "string"
        },
        "authority_state": {
          "type": "string",
          "enum": [
            "CANONICAL_AUTHORITY",
            "EVIDENCE_ONLY",
            "DISPLAY_ONLY",
            "LEGACY_REFERENCE",
            "NON_CANONICAL",
            "UNKNOWN"
          ]
        },
        "source_path": {
          "type": "string"
        },
        "source_type": {
          "type": "string"
        },
        "freshness": {
          "$ref": "#/$defs/freshness"
        },
        "blocked_actions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "next_safe_action": {
          "type": "string"
        },
        "approval_required": {
          "type": "boolean"
        },
        "execution_allowed": {
          "type": "boolean",
          "const": false
        },
        "mutation_allowed": {
          "type": "boolean",
          "const": false
        },
        "stale_or_legacy": {
          "type": "boolean"
        },
        "safe_for_frontend_display": {
          "type": "boolean"
        }
      }
    },
    "next_safe_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rank",
        "action",
        "requires_human_approval",
        "reason"
      ],
      "properties": {
        "rank": {
          "type": "integer",
          "minimum": 1
        },
        "action": {
          "type": "string"
        },
        "requires_human_approval": {
          "type": "boolean"
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "stale_condition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "condition",
        "severity",
        "next_safe_action"
      ],
      "properties": {
        "source": {
          "type": "string"
        },
        "condition": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": [
            "REVIEW",
            "WARNING",
            "BLOCKED"
          ]
        },
        "next_safe_action": {
          "type": "string"
        }
      }
    }
  }
}
