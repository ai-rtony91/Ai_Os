{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aios.local/schemas/orchestration/runtime_state_bundle.schema.json",
  "title": "AI_OS Runtime State Bundle",
  "description": "Read-only runtime aggregation contract for AI_OS orchestration evidence. This schema describes generated evidence only and does not grant mutation authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "schema_version",
    "generated_at",
    "mode",
    "authority_boundary",
    "packet_state",
    "worker_state",
    "lock_state",
    "validator_state",
    "approval_state",
    "escalation_state",
    "git_state",
    "supervisor_state",
    "next_safe_actions",
    "stale_conditions",
    "confidence_state"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "AIOS_RUNTIME_STATE_BUNDLE.v1"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "generated_at": {
      "type": "string",
      "description": "ISO-like timestamp when this read-only bundle was generated."
    },
    "mode": {
      "type": "string",
      "const": "DRY_RUN"
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "read_only",
        "approval_authority",
        "generated_evidence_only",
        "blocked_capabilities"
      ],
      "properties": {
        "read_only": {
          "type": "boolean",
          "const": true
        },
        "approval_authority": {
          "type": "string"
        },
        "generated_evidence_only": {
          "type": "boolean",
          "const": true
        },
        "blocked_capabilities": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "packet_state": {
      "$ref": "#/$defs/runtime_section"
    },
    "worker_state": {
      "$ref": "#/$defs/runtime_section"
    },
    "lock_state": {
      "$ref": "#/$defs/runtime_section"
    },
    "validator_state": {
      "$ref": "#/$defs/runtime_section"
    },
    "approval_state": {
      "$ref": "#/$defs/runtime_section"
    },
    "escalation_state": {
      "$ref": "#/$defs/runtime_section"
    },
    "git_state": {
      "$ref": "#/$defs/runtime_section"
    },
    "supervisor_state": {
      "$ref": "#/$defs/runtime_section"
    },
    "next_safe_actions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/next_safe_action"
      }
    },
    "stale_conditions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stale_condition"
      }
    },
    "confidence_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "overall_confidence",
        "confidence_score",
        "confidence_reasons"
      ],
      "properties": {
        "overall_confidence": {
          "type": "string",
          "enum": [
            "HIGH",
            "MEDIUM",
            "LOW",
            "BLOCKED",
            "UNKNOWN"
          ]
        },
        "confidence_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "confidence_reasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "$defs": {
    "runtime_section": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "source_paths",
        "summary",
        "items",
        "freshness",
        "blocked_actions"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "READY",
            "REVIEW",
            "WARNING",
            "BLOCKED",
            "UNKNOWN"
          ]
        },
        "source_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "summary": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "freshness": {
          "$ref": "#/$defs/freshness"
        },
        "blocked_actions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checked_at",
        "ttl_seconds",
        "is_stale"
      ],
      "properties": {
        "checked_at": {
          "type": "string"
        },
        "ttl_seconds": {
          "type": "integer",
          "minimum": 0
        },
        "is_stale": {
          "type": "boolean"
        }
      }
    },
    "next_safe_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rank",
        "action",
        "requires_human_approval",
        "reason"
      ],
      "properties": {
        "rank": {
          "type": "integer",
          "minimum": 1
        },
        "action": {
          "type": "string"
        },
        "requires_human_approval": {
          "type": "boolean"
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "stale_condition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "condition",
        "severity",
        "next_safe_action"
      ],
      "properties": {
        "source": {
          "type": "string"
        },
        "condition": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": [
            "REVIEW",
            "WARNING",
            "BLOCKED"
          ]
        },
        "next_safe_action": {
          "type": "string"
        }
      }
    }
  }
}
