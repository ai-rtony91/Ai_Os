  "title": "AI_OS Orchestration Schema Index",
  "description": "Machine-readable v0.1.1 index for AI_OS orchestration schema contract files. This index is documentation and discovery metadata only; it does not execute, approve, validate, commit, push, deploy, or mutate runtime state.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "contracts",
    "safety"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1.1"
    },
    "contracts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "name",
          "path",
          "kind",
          "purpose"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "enum": [
              "markdown",
              "json_schema",
              "index"
            ]
          },
          "purpose": {
            "type": "string"
          },
          "reconciliation_version": {
            "type": "string"
          }
        }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "contract_only",
        "runtime_mutation",
        "approval_authority",
        "execution_authority"
      ],
      "properties": {
        "contract_only": {
          "type": "boolean",
          "const": true
        },
        "runtime_mutation": {
          "type": "boolean",
          "const": false
        },
        "approval_authority": {
          "type": "boolean",
          "const": false
        },
        "execution_authority": {
          "type": "boolean",
          "const": false
        }
      }
    }
  },
