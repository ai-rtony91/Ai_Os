{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-os.local/schemas/aios/orchestration/WORKER_REGISTRY_SCHEMA.v0.1",
  "title": "AI_OS Worker Registry Schema",
  "description": "v0.1 JSON Schema for AI_OS worker registry structure. Contract scaffold only; it does not register, launch, assign, approve, or execute workers.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "registry_id",
    "version",
    "workers"
  ],
  "properties": {
    "registry_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "workers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "worker_id",
          "type",
          "purpose"
        ],
        "properties": {
          "worker_id": {
            "type": "string",
            "minLength": 1
          },
          "window_marker": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "minLength": 1
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string"
          },
          "allowed_actions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "blocked_actions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "allowed_paths": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "blocked_paths": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
