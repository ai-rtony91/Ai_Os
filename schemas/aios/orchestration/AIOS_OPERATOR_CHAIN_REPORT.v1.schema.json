{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "AIOS_OPERATOR_CHAIN_REPORT.v1",
  "title": "AIOS Operator Chain Report V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "generated_at_utc",
    "component",
    "mode",
    "report_id",
    "verdict",
    "report_state",
    "inherited_chain_id",
    "inherited_chain_verdict",
    "inherited_chain_state",
    "first_blocking_component",
    "human_approval_required",
    "explicit_human_approval_present",
    "apply_review_ready",
    "hard_safety_all_false",
    "component_verdicts",
    "component_states",
    "blockers",
    "report_json",
    "report_markdown",
    "next_safe_action",
    "self_approval_allowed",
    "apply_allowed",
    "apply_performed",
    "commands_executed",
    "files_written",
    "mutations_performed",
    "executable_packet_emitted",
    "execution_token_emitted",
    "codex_prompt_emitted",
    "worker_launch_allowed",
    "scheduler_allowed",
    "daemon_allowed",
    "broker_allowed",
    "live_trading_allowed",
    "production_allowed",
    "dashboard_mutation_allowed",
    "commit_allowed",
    "push_allowed",
    "merge_allowed",
    "safety"
  ],
  "properties": {
    "schema": { "const": "AIOS_OPERATOR_CHAIN_REPORT.v1" },
    "generated_at_utc": { "type": "string", "minLength": 1 },
    "component": { "const": "operator_chain_report" },
    "mode": { "const": "READ_ONLY_OPERATOR_CHAIN_REPORT" },
    "report_id": { "type": "string", "minLength": 1 },
    "verdict": {
      "enum": [
        "REPORT_BLOCKED_CHAIN",
        "REPORT_HUMAN_APPROVAL_REQUIRED",
        "REPORT_APPLY_REVIEW_READY",
        "REPORT_CHAIN_REVIEW_COMPLETE",
        "REPORT_REVIEW_REQUIRED",
        "BLOCKED_CHAIN_RESULT_MISSING",
        "BLOCKED_CHAIN_RESULT_MALFORMED",
        "BLOCKED_UNSAFE_CONTENT",
        "BLOCKED_EXECUTABLE_CONTENT",
        "BLOCKED_HARD_SAFETY_VIOLATION"
      ]
    },
    "report_state": { "type": "string", "minLength": 1 },
    "inherited_chain_id": { "type": "string" },
    "inherited_chain_verdict": { "type": "string" },
    "inherited_chain_state": { "type": "string" },
    "first_blocking_component": {
      "anyOf": [
        { "type": "string" },
        { "type": "null" }
      ]
    },
    "human_approval_required": { "type": "boolean" },
    "explicit_human_approval_present": { "type": "boolean" },
    "apply_review_ready": { "type": "boolean" },
    "hard_safety_all_false": { "type": "boolean" },
    "component_verdicts": { "type": "object" },
    "component_states": { "type": "object" },
    "blockers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "report_json": { "type": "object" },
    "report_markdown": { "type": "string" },
    "next_safe_action": { "type": "string" },
    "self_approval_allowed": { "const": false },
    "apply_allowed": { "const": false },
    "apply_performed": { "const": false },
    "commands_executed": { "const": false },
    "files_written": { "const": false },
    "mutations_performed": { "const": false },
    "executable_packet_emitted": { "const": false },
    "execution_token_emitted": { "const": false },
    "codex_prompt_emitted": { "const": false },
    "worker_launch_allowed": { "const": false },
    "scheduler_allowed": { "const": false },
    "daemon_allowed": { "const": false },
    "broker_allowed": { "const": false },
    "live_trading_allowed": { "const": false },
    "production_allowed": { "const": false },
    "dashboard_mutation_allowed": { "const": false },
    "commit_allowed": { "const": false },
    "push_allowed": { "const": false },
    "merge_allowed": { "const": false },
    "safety": { "type": "object" }
  }
}
