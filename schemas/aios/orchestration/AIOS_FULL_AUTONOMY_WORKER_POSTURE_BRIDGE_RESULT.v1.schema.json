{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aios.local/schemas/orchestration/AIOS_FULL_AUTONOMY_WORKER_POSTURE_BRIDGE_RESULT.v1.schema.json",
  "title": "AIOS Full Autonomy Worker Posture Bridge Result v1",
  "description": "Console-only read-only worker posture bridge result. This schema grants no worker launch, APPLY, approval, queue, lock, relay, runtime, scheduler, broker, trading, commit, push, PR, or merge authority.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema",
    "mode",
    "generated_utc",
    "repo_state",
    "activation_summary",
    "worker_posture",
    "worker_shift_mode",
    "recommended_worker_count",
    "max_parallel_workers",
    "allowed_worker_lanes",
    "blocked_worker_lanes",
    "worker_launch_allowed",
    "worker_launch_reason",
    "human_wake_policy",
    "recommended_validators",
    "safety",
    "no_write_proof",
    "stop_conditions",
    "next_safe_action"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "AIOS_FULL_AUTONOMY_WORKER_POSTURE_BRIDGE_RESULT.v1"
    },
    "mode": {
      "type": "string",
      "const": "DRY_RUN_READ_ONLY"
    },
    "generated_utc": {
      "type": "string"
    },
    "repo_state": {
      "type": "object",
      "additionalProperties": true
    },
    "activation_summary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "requested_autonomy_level",
        "operating_profile",
        "activation_status",
        "human_owner_approval_evidence_present",
        "worker_launch_allowed_by_activation_gate"
      ],
      "properties": {
        "worker_launch_allowed_by_activation_gate": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "worker_posture": {
      "type": "string",
      "enum": [
        "NO_WORKERS",
        "READ_ONLY_VALIDATOR_CREW",
        "PACKET_PREVIEW_CREW",
        "SUPERVISED_DAY_CREW_12H",
        "SUPERVISED_DAY_NIGHT_CREW_24H",
        "WEEKEND_LOW_TOUCH_CREW",
        "VACATION_EMERGENCY_ONLY_CREW",
        "BLOCKED_BY_APPROVAL",
        "BLOCKED_BY_SOS",
        "BLOCKED_BY_VALIDATION"
      ]
    },
    "worker_shift_mode": {
      "type": "string"
    },
    "recommended_worker_count": {
      "type": "integer",
      "minimum": 0
    },
    "max_parallel_workers": {
      "type": "integer",
      "minimum": 0
    },
    "allowed_worker_lanes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blocked_worker_lanes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "worker_launch_allowed": {
      "type": "boolean",
      "const": false
    },
    "worker_launch_reason": {
      "type": "string"
    },
    "human_wake_policy": {
      "type": "string"
    },
    "recommended_validators": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "status",
        "console_only",
        "writes_files",
        "writes_reports",
        "writes_telemetry",
        "creates_ready_stage",
        "mutates_registry",
        "mutates_queue",
        "mutates_locks",
        "mutates_approval",
        "mutates_approvals",
        "writes_relay",
        "starts_runtime",
        "launches_workers",
        "worker_reservation_allowed",
        "enables_scheduler",
        "starts_daemon",
        "touches_secrets_or_env",
        "secrets_or_env_access",
        "broker_or_live_trading",
        "worker_launch_allowed",
        "advisory_only",
        "protected_actions_blocked",
        "human_owner_required_before_worker_launch",
        "human_owner_required_before_protected_action",
        "self_approval_allowed"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "PASS",
            "REVIEW_REQUIRED",
            "BLOCKED",
            "BLOCKED_BY_WRITE_SURFACE_RISK"
          ]
        },
        "console_only": {
          "type": "boolean",
          "const": true
        },
        "writes_files": {
          "type": "boolean",
          "const": false
        },
        "writes_reports": {
          "type": "boolean",
          "const": false
        },
        "writes_telemetry": {
          "type": "boolean",
          "const": false
        },
        "creates_ready_stage": {
          "type": "boolean",
          "const": false
        },
        "mutates_registry": {
          "type": "boolean",
          "const": false
        },
        "mutates_queue": {
          "type": "boolean",
          "const": false
        },
        "mutates_locks": {
          "type": "boolean",
          "const": false
        },
        "mutates_approval": {
          "type": "boolean",
          "const": false
        },
        "mutates_approvals": {
          "type": "boolean",
          "const": false
        },
        "writes_relay": {
          "type": "boolean",
          "const": false
        },
        "starts_runtime": {
          "type": "boolean",
          "const": false
        },
        "launches_workers": {
          "type": "boolean",
          "const": false
        },
        "worker_reservation_allowed": {
          "type": "boolean",
          "const": false
        },
        "enables_scheduler": {
          "type": "boolean",
          "const": false
        },
        "starts_daemon": {
          "type": "boolean",
          "const": false
        },
        "touches_secrets_or_env": {
          "type": "boolean",
          "const": false
        },
        "secrets_or_env_access": {
          "type": "boolean",
          "const": false
        },
        "broker_or_live_trading": {
          "type": "boolean",
          "const": false
        },
        "worker_launch_allowed": {
          "type": "boolean",
          "const": false
        },
        "advisory_only": {
          "type": "boolean",
          "const": true
        },
        "protected_actions_blocked": {
          "type": "boolean",
          "const": true
        },
        "human_owner_required_before_worker_launch": {
          "type": "boolean",
          "const": true
        },
        "human_owner_required_before_protected_action": {
          "type": "boolean",
          "const": true
        },
        "self_approval_allowed": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "no_write_proof": {
      "type": "object",
      "additionalProperties": true
    },
    "stop_conditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_safe_action": {
      "type": "string"
    }
  }
}
