{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aios.local/schemas/orchestration/AIOS_FULL_AUTONOMY_WORKER_LAUNCH_COMMAND_RESULT.v1.schema.json",
  "title": "AIOS Full Autonomy Worker Launch Command Result v1",
  "description": "Console-only read-only worker launch command preview result. This schema grants no worker launch, APPLY, approval, queue, lock, relay, runtime, scheduler, broker, trading, commit, push, PR, or merge authority.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema",
    "mode",
    "generated_utc",
    "repo_state",
    "input_preflight_summary",
    "command_decision",
    "worker_launch_command_preview",
    "worker_count",
    "worker_posture",
    "allowed_lanes",
    "blocked_lanes",
    "timebox_minutes",
    "stop_conditions",
    "required_validators_before_launch",
    "human_owner_approval_required",
    "launch_executed",
    "safety",
    "no_write_proof",
    "next_safe_action"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "AIOS_FULL_AUTONOMY_WORKER_LAUNCH_COMMAND_RESULT.v1"
    },
    "mode": {
      "type": "string",
      "const": "DRY_RUN_READ_ONLY"
    },
    "generated_utc": {
      "type": "string"
    },
    "repo_state": {
      "type": "object",
      "additionalProperties": true
    },
    "input_preflight_summary": {
      "type": "object",
      "additionalProperties": true
    },
    "command_decision": {
      "type": "string",
      "enum": [
        "NO_COMMAND",
        "COMMAND_PREVIEW_BLOCKED",
        "COMMAND_PREVIEW_REVIEW_REQUIRED",
        "COMMAND_PREVIEW_READY_AWAITING_APPROVAL",
        "COMMAND_PREVIEW_READY_APPROVED_BUT_NOT_EXECUTED"
      ]
    },
    "worker_launch_command_preview": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "executable_in_this_packet",
        "requires_separate_approved_launch_packet",
        "launch_executed"
      ],
      "properties": {
        "executable_in_this_packet": {
          "type": "boolean",
          "const": false
        },
        "requires_separate_approved_launch_packet": {
          "type": "boolean",
          "const": true
        },
        "launch_executed": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "worker_count": {
      "type": "integer",
      "minimum": 0
    },
    "worker_posture": {
      "type": "string"
    },
    "allowed_lanes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blocked_lanes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "timebox_minutes": {
      "type": "integer",
      "minimum": 1
    },
    "stop_conditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "required_validators_before_launch": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "human_owner_approval_required": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "required",
        "present",
        "required_before_future_launch_packet",
        "validator_pass_is_not_approval",
        "self_approval_allowed"
      ],
      "properties": {
        "required": {
          "type": "boolean",
          "const": true
        },
        "required_before_future_launch_packet": {
          "type": "boolean",
          "const": true
        },
        "validator_pass_is_not_approval": {
          "type": "boolean",
          "const": true
        },
        "self_approval_allowed": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "launch_executed": {
      "type": "boolean",
      "const": false
    },
    "safety": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "status",
        "writes_files",
        "starts_runtime",
        "launches_workers",
        "enables_scheduler",
        "starts_daemon",
        "mutates_queue",
        "mutates_locks",
        "mutates_approval",
        "mutates_registry",
        "writes_reports",
        "writes_telemetry",
        "writes_relay",
        "touches_secrets_or_env",
        "broker_or_live_trading",
        "protected_actions_blocked",
        "human_owner_required_before_worker_launch"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "PASS",
            "REVIEW_REQUIRED",
            "BLOCKED",
            "BLOCKED_BY_WRITE_SURFACE_RISK"
          ]
        },
        "writes_files": {
          "type": "boolean",
          "const": false
        },
        "starts_runtime": {
          "type": "boolean",
          "const": false
        },
        "launches_workers": {
          "type": "boolean",
          "const": false
        },
        "enables_scheduler": {
          "type": "boolean",
          "const": false
        },
        "starts_daemon": {
          "type": "boolean",
          "const": false
        },
        "mutates_queue": {
          "type": "boolean",
          "const": false
        },
        "mutates_locks": {
          "type": "boolean",
          "const": false
        },
        "mutates_approval": {
          "type": "boolean",
          "const": false
        },
        "mutates_registry": {
          "type": "boolean",
          "const": false
        },
        "writes_reports": {
          "type": "boolean",
          "const": false
        },
        "writes_telemetry": {
          "type": "boolean",
          "const": false
        },
        "writes_relay": {
          "type": "boolean",
          "const": false
        },
        "touches_secrets_or_env": {
          "type": "boolean",
          "const": false
        },
        "broker_or_live_trading": {
          "type": "boolean",
          "const": false
        },
        "protected_actions_blocked": {
          "type": "boolean",
          "const": true
        },
        "human_owner_required_before_worker_launch": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "no_write_proof": {
      "type": "object",
      "additionalProperties": true
    },
    "next_safe_action": {
      "type": "string"
    }
  }
}
