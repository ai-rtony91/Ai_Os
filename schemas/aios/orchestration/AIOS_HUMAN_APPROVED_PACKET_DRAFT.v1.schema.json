{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "AIOS_HUMAN_APPROVED_PACKET_DRAFT.v1",
  "title": "AIOS Human Approved Packet Draft V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "generated_at_utc",
    "component",
    "mode",
    "draft_id",
    "verdict",
    "draft_state",
    "source_report_id",
    "source_report_verdict",
    "source_chain_verdict",
    "source_chain_state",
    "packet_draft",
    "packet_draft_created",
    "non_executable_draft_only",
    "human_approval_required_before_execution",
    "self_approval_allowed",
    "apply_allowed",
    "apply_performed",
    "commands_executed",
    "files_written",
    "mutations_performed",
    "executable_packet_emitted",
    "execution_token_emitted",
    "codex_prompt_emitted",
    "worker_launch_allowed",
    "scheduler_allowed",
    "daemon_allowed",
    "broker_allowed",
    "live_trading_allowed",
    "production_allowed",
    "dashboard_mutation_allowed",
    "commit_allowed",
    "push_allowed",
    "merge_allowed",
    "blockers",
    "evidence_inputs",
    "next_safe_action",
    "safety"
  ],
  "properties": {
    "schema": { "const": "AIOS_HUMAN_APPROVED_PACKET_DRAFT.v1" },
    "generated_at_utc": { "type": "string", "minLength": 1 },
    "component": { "const": "human_approved_packet_draft_generator" },
    "mode": { "const": "READ_ONLY_NON_EXECUTABLE_PACKET_DRAFT" },
    "draft_id": { "type": "string", "minLength": 1 },
    "verdict": {
      "enum": [
        "PACKET_DRAFT_READY",
        "BLOCKED_OPERATOR_REPORT_MISSING",
        "BLOCKED_OPERATOR_REPORT_MALFORMED",
        "BLOCKED_OPERATOR_REPORT_NOT_READY",
        "BLOCKED_HARD_SAFETY_VIOLATION",
        "BLOCKED_PACKET_SCOPE_UNKNOWN",
        "BLOCKED_UNSAFE_CONTENT",
        "BLOCKED_EXECUTABLE_CONTENT",
        "BLOCKED_NO_SAFE_DRAFT"
      ]
    },
    "draft_state": { "type": "string", "minLength": 1 },
    "source_report_id": { "type": "string" },
    "source_report_verdict": { "type": "string" },
    "source_chain_verdict": { "type": "string" },
    "source_chain_state": { "type": "string" },
    "packet_draft": {
      "anyOf": [
        { "type": "object" },
        { "type": "null" }
      ]
    },
    "packet_draft_created": { "type": "boolean" },
    "non_executable_draft_only": { "const": true },
    "human_approval_required_before_execution": { "const": true },
    "self_approval_allowed": { "const": false },
    "apply_allowed": { "const": false },
    "apply_performed": { "const": false },
    "commands_executed": { "const": false },
    "files_written": { "const": false },
    "mutations_performed": { "const": false },
    "executable_packet_emitted": { "const": false },
    "execution_token_emitted": { "const": false },
    "codex_prompt_emitted": { "const": false },
    "worker_launch_allowed": { "const": false },
    "scheduler_allowed": { "const": false },
    "daemon_allowed": { "const": false },
    "broker_allowed": { "const": false },
    "live_trading_allowed": { "const": false },
    "production_allowed": { "const": false },
    "dashboard_mutation_allowed": { "const": false },
    "commit_allowed": { "const": false },
    "push_allowed": { "const": false },
    "merge_allowed": { "const": false },
    "blockers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "evidence_inputs": {
      "type": "array",
      "items": { "type": "object" }
    },
    "next_safe_action": { "type": "string" },
    "safety": { "type": "object" }
  }
}
