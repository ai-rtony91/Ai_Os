{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-os.local/schemas/aios/orchestration/COMMAND_QUEUE_SCHEMA.v0.1",
  "title": "AI_OS Command Queue Schema",
  "description": "v0.1 JSON Schema for AI_OS command queue entries. Contract scaffold only; queued commands are not execution authority.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "queue_id",
    "version",
    "commands"
  ],
  "properties": {
    "queue_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "command_id",
          "command",
          "status",
          "created_at"
        ],
        "properties": {
          "command_id": {
            "type": "string",
            "minLength": 1
          },
          "packet_id": {
            "type": "string"
          },
          "command": {
            "type": [
              "string",
              "array"
            ]
          },
          "mode": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "minLength": 1
          },
          "requested_by": {
            "type": "string"
          },
          "approval_required": {
            "type": "boolean"
          },
          "created_at": {
            "type": "string"
          },
          "updated_at": {
            "type": "string"
          },
          "evidence_paths": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "next_safe_action": {
            "type": "string"
          }
        }
      }
    }
  }
}
