{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/aios/orchestration/ORCHESTRATION_DECISION.schema.json",
  "title": "AI_OS Orchestration Decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "decision_id",
    "mode",
    "local_fixture_only",
    "manager_owner",
    "specialist",
    "default_pattern",
    "handoff_required",
    "handoff_justification",
    "manager_owns_final_answer",
    "manager_owns_validator_chain",
    "manager_owns_approval_gate",
    "allowed_paths",
    "forbidden_paths",
    "commit_allowed",
    "push_allowed",
    "merge_allowed",
    "pi_motor_control_allowed",
    "live_trading_status",
    "broker_execution_status",
    "oanda_status",
    "profitability_priority"
  ],
  "properties": {
    "decision_id": { "type": "string" },
    "mode": { "type": "string", "enum": ["DRY_RUN"] },
    "local_fixture_only": { "type": "boolean", "const": true },
    "manager_owner": { "type": "string", "const": "AI_OS_MANAGER" },
    "specialist": { "type": "string" },
    "default_pattern": { "type": "string", "enum": ["AGENT_AS_TOOL", "HANDOFF"] },
    "handoff_required": { "type": "boolean" },
    "handoff_justification": { "type": "string" },
    "manager_owns_final_answer": { "type": "boolean", "const": true },
    "manager_owns_validator_chain": { "type": "boolean", "const": true },
    "manager_owns_approval_gate": { "type": "boolean", "const": true },
    "allowed_paths": { "type": "array", "items": { "type": "string" } },
    "forbidden_paths": { "type": "array", "items": { "type": "string" } },
    "commit_allowed": { "type": "boolean", "const": false },
    "push_allowed": { "type": "boolean", "const": false },
    "merge_allowed": { "type": "boolean", "const": false },
    "pi_motor_control_allowed": { "type": "boolean", "const": false },
    "live_trading_status": { "type": "string", "const": "BLOCKED" },
    "broker_execution_status": { "type": "string", "const": "BLOCKED" },
    "oanda_status": { "type": "string", "const": "BLOCKED" },
    "profitability_priority": { "type": "string", "const": "TRUSTED_PROVEN_PROFITABILITY_BEFORE_FEATURE_EXPANSION" }
  }
}

