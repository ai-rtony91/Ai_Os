{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aios.local/schemas/orchestration/AIOS_SELF_AUTONOMY_APPLY_GATE.v1.schema.json",
  "title": "AIOS Self-Autonomy Apply Gate v1",
  "description": "Read-only eligibility gate for human APPLY review after a safe M13 dry-run simulation. This schema grants no apply, command execution, file write, Reports output, runtime mutation, approval mutation, queue mutation, worker launch, scheduler, broker, live-trading, production, dashboard mutation, commit, push, or merge authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "generated_at_utc",
    "component",
    "mode",
    "gate_id",
    "inherited_execution_id",
    "inherited_plan_id",
    "inherited_execution_verdict",
    "verdict",
    "gate_state",
    "dry_run_valid",
    "scope_valid",
    "validators_known",
    "rollback_path_known",
    "human_approval_required",
    "explicit_human_approval_present",
    "approval_scope_matches",
    "apply_review_ready",
    "apply_allowed",
    "apply_performed",
    "commands_executed",
    "files_written",
    "mutations_performed",
    "executable_packet_emitted",
    "execution_token_emitted",
    "codex_prompt_emitted",
    "worker_launch_allowed",
    "scheduler_allowed",
    "daemon_allowed",
    "broker_allowed",
    "live_trading_allowed",
    "production_allowed",
    "dashboard_mutation_allowed",
    "commit_allowed",
    "push_allowed",
    "merge_allowed",
    "allowed_paths",
    "forbidden_paths",
    "validator_chain",
    "rollback_note",
    "blockers",
    "evidence_inputs",
    "next_safe_action",
    "safety"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "AIOS_SELF_AUTONOMY_APPLY_GATE.v1"
    },
    "generated_at_utc": {
      "type": "string",
      "minLength": 1
    },
    "component": {
      "type": "string",
      "const": "self_autonomy_apply_gate"
    },
    "mode": {
      "type": "string",
      "const": "READ_ONLY_APPLY_REVIEW_ELIGIBILITY_GATE"
    },
    "gate_id": {
      "type": "string",
      "minLength": 1
    },
    "inherited_execution_id": {
      "type": "string"
    },
    "inherited_plan_id": {
      "type": "string"
    },
    "inherited_execution_verdict": {
      "type": "string"
    },
    "verdict": {
      "type": "string",
      "enum": [
        "APPLY_REVIEW_READY",
        "HUMAN_APPROVAL_REQUIRED",
        "BLOCKED_DRY_RUN_MISSING",
        "BLOCKED_DRY_RUN_NOT_READY",
        "BLOCKED_SCOPE_UNKNOWN",
        "BLOCKED_SCOPE_UNSAFE",
        "BLOCKED_VALIDATORS_UNKNOWN",
        "BLOCKED_ROLLBACK_MISSING",
        "BLOCKED_APPROVAL_SCOPE_MISMATCH",
        "BLOCKED_UNSAFE_SCOPE",
        "BLOCKED_EXECUTION_SIDE_EFFECT",
        "BLOCKED_NO_SAFE_APPLY_REVIEW"
      ]
    },
    "gate_state": {
      "type": "string",
      "enum": ["READY_FOR_HUMAN_APPLY_REVIEW", "WAITING_FOR_HUMAN_APPROVAL", "BLOCKED"]
    },
    "dry_run_valid": {
      "type": "boolean"
    },
    "scope_valid": {
      "type": "boolean"
    },
    "validators_known": {
      "type": "boolean"
    },
    "rollback_path_known": {
      "type": "boolean"
    },
    "human_approval_required": {
      "type": "boolean",
      "const": true
    },
    "explicit_human_approval_present": {
      "type": "boolean"
    },
    "approval_scope_matches": {
      "type": "boolean"
    },
    "apply_review_ready": {
      "type": "boolean"
    },
    "apply_allowed": {
      "type": "boolean",
      "const": false
    },
    "apply_performed": {
      "type": "boolean",
      "const": false
    },
    "commands_executed": {
      "type": "boolean",
      "const": false
    },
    "files_written": {
      "type": "boolean",
      "const": false
    },
    "mutations_performed": {
      "type": "boolean",
      "const": false
    },
    "executable_packet_emitted": {
      "type": "boolean",
      "const": false
    },
    "execution_token_emitted": {
      "type": "boolean",
      "const": false
    },
    "codex_prompt_emitted": {
      "type": "boolean",
      "const": false
    },
    "worker_launch_allowed": {
      "type": "boolean",
      "const": false
    },
    "scheduler_allowed": {
      "type": "boolean",
      "const": false
    },
    "daemon_allowed": {
      "type": "boolean",
      "const": false
    },
    "broker_allowed": {
      "type": "boolean",
      "const": false
    },
    "live_trading_allowed": {
      "type": "boolean",
      "const": false
    },
    "production_allowed": {
      "type": "boolean",
      "const": false
    },
    "dashboard_mutation_allowed": {
      "type": "boolean",
      "const": false
    },
    "commit_allowed": {
      "type": "boolean",
      "const": false
    },
    "push_allowed": {
      "type": "boolean",
      "const": false
    },
    "merge_allowed": {
      "type": "boolean",
      "const": false
    },
    "allowed_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "forbidden_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validator_chain": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rollback_note": {
      "type": "string"
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status", "schema"],
        "properties": {
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "schema": {
            "type": ["string", "null"]
          }
        }
      }
    },
    "next_safe_action": {
      "type": "string",
      "minLength": 1
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "read_only",
        "side_effect_free",
        "eligibility_only",
        "commands_executed",
        "files_written",
        "reports_written",
        "runtime_mutation",
        "approval_mutation",
        "queue_mutation",
        "apply_performed"
      ],
      "properties": {
        "read_only": {
          "type": "boolean",
          "const": true
        },
        "side_effect_free": {
          "type": "boolean",
          "const": true
        },
        "eligibility_only": {
          "type": "boolean",
          "const": true
        },
        "commands_executed": {
          "type": "boolean",
          "const": false
        },
        "files_written": {
          "type": "boolean",
          "const": false
        },
        "reports_written": {
          "type": "boolean",
          "const": false
        },
        "runtime_mutation": {
          "type": "boolean",
          "const": false
        },
        "approval_mutation": {
          "type": "boolean",
          "const": false
        },
        "queue_mutation": {
          "type": "boolean",
          "const": false
        },
        "apply_performed": {
          "type": "boolean",
          "const": false
        }
      }
    }
  }
}
