{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aios.local/schemas/orchestration/AIOS_FULL_AUTONOMY_WORKER_LAUNCH_GUARD_RESULT.v1.schema.json",
  "title": "AIOS Full Autonomy Worker Launch Guard Result v1",
  "description": "Console-only read-only worker launch guard result. This schema grants no worker launch, APPLY, approval, queue, lock, relay, runtime, scheduler, broker, trading, commit, push, PR, or merge authority.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema",
    "mode",
    "generated_utc",
    "repo_state",
    "guard_decision",
    "input_command_summary",
    "approval_state",
    "validator_state",
    "lane_state",
    "worker_count_state",
    "sos_state",
    "launch_allowed_for_future_packet",
    "launch_executed",
    "safety",
    "no_write_proof",
    "stop_conditions",
    "next_safe_action"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "AIOS_FULL_AUTONOMY_WORKER_LAUNCH_GUARD_RESULT.v1"
    },
    "mode": {
      "type": "string",
      "const": "DRY_RUN_READ_ONLY"
    },
    "generated_utc": {
      "type": "string"
    },
    "repo_state": {
      "type": "object",
      "additionalProperties": true
    },
    "guard_decision": {
      "type": "string",
      "enum": [
        "LAUNCH_DENIED",
        "LAUNCH_REVIEW_REQUIRED",
        "LAUNCH_AWAITING_HUMAN_APPROVAL",
        "LAUNCH_APPROVED_FOR_FUTURE_PACKET_NOT_EXECUTED",
        "BLOCKED_BY_SOS",
        "BLOCKED_BY_VALIDATORS",
        "BLOCKED_BY_LANES",
        "BLOCKED_BY_WORKER_COUNT",
        "BLOCKED_BY_REPO_STATE"
      ]
    },
    "input_command_summary": {
      "type": "object",
      "additionalProperties": true
    },
    "approval_state": {
      "type": "object",
      "additionalProperties": true
    },
    "validator_state": {
      "type": "object",
      "additionalProperties": true
    },
    "lane_state": {
      "type": "object",
      "additionalProperties": true
    },
    "worker_count_state": {
      "type": "object",
      "additionalProperties": true
    },
    "sos_state": {
      "type": "object",
      "additionalProperties": true
    },
    "launch_allowed_for_future_packet": {
      "type": "boolean"
    },
    "launch_executed": {
      "type": "boolean",
      "const": false
    },
    "safety": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "status",
        "writes_files",
        "starts_runtime",
        "launches_workers",
        "enables_scheduler",
        "starts_daemon",
        "mutates_queue",
        "mutates_locks",
        "mutates_approval",
        "mutates_registry",
        "writes_reports",
        "writes_telemetry",
        "writes_relay",
        "touches_secrets_or_env",
        "broker_or_live_trading",
        "protected_actions_blocked",
        "human_owner_required_before_worker_launch"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "PASS",
            "REVIEW_REQUIRED",
            "BLOCKED",
            "BLOCKED_BY_WRITE_SURFACE_RISK"
          ]
        },
        "writes_files": {
          "type": "boolean",
          "const": false
        },
        "starts_runtime": {
          "type": "boolean",
          "const": false
        },
        "launches_workers": {
          "type": "boolean",
          "const": false
        },
        "enables_scheduler": {
          "type": "boolean",
          "const": false
        },
        "starts_daemon": {
          "type": "boolean",
          "const": false
        },
        "mutates_queue": {
          "type": "boolean",
          "const": false
        },
        "mutates_locks": {
          "type": "boolean",
          "const": false
        },
        "mutates_approval": {
          "type": "boolean",
          "const": false
        },
        "mutates_registry": {
          "type": "boolean",
          "const": false
        },
        "writes_reports": {
          "type": "boolean",
          "const": false
        },
        "writes_telemetry": {
          "type": "boolean",
          "const": false
        },
        "writes_relay": {
          "type": "boolean",
          "const": false
        },
        "touches_secrets_or_env": {
          "type": "boolean",
          "const": false
        },
        "broker_or_live_trading": {
          "type": "boolean",
          "const": false
        },
        "protected_actions_blocked": {
          "type": "boolean",
          "const": true
        },
        "human_owner_required_before_worker_launch": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "no_write_proof": {
      "type": "object",
      "additionalProperties": true
    },
    "stop_conditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_safe_action": {
      "type": "string"
    }
  }
}
