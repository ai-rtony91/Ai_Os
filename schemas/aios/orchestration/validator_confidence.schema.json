{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aios.local/schemas/orchestration/validator_confidence.schema.json",
  "title": "AI_OS Validator Confidence",
  "description": "Read-only validator confidence evidence for AI_OS runtime and auto-git decisions. This schema does not authorize APPLY, staging, committing, pushing, merging, approval mutation, packet movement, or runtime writes.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "schema_version",
    "generated_at",
    "mode",
    "overall_result",
    "confidence_score",
    "confidence_band",
    "required_validators_missing",
    "failed_validators",
    "blocked_findings",
    "review_findings",
    "weighted_findings",
    "source_reports",
    "safe_auto_allowed_eligible",
    "stop_conditions",
    "authority_boundary"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "AIOS_VALIDATOR_CONFIDENCE.v1"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "generated_at": {
      "type": "string"
    },
    "mode": {
      "type": "string",
      "const": "DRY_RUN"
    },
    "overall_result": {
      "type": "string",
      "enum": [
        "PASS",
        "REVIEW_REQUIRED",
        "BLOCKED",
        "UNKNOWN"
      ]
    },
    "confidence_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "confidence_band": {
      "type": "string",
      "enum": [
        "HIGH",
        "MEDIUM",
        "LOW",
        "BLOCKED"
      ]
    },
    "required_validators_missing": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "failed_validators": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blocked_findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "review_findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "weighted_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source",
          "severity",
          "weight",
          "reason"
        ],
        "properties": {
          "source": {
            "type": "string"
          },
          "severity": {
            "type": "string"
          },
          "weight": {
            "type": "integer"
          },
          "reason": {
            "type": "string"
          }
        }
      }
    },
    "source_reports": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "safe_auto_allowed_eligible": {
      "type": "boolean"
    },
    "stop_conditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "read_only",
        "execution_enabled",
        "approval_authority",
        "blocked_capabilities"
      ],
      "properties": {
        "read_only": {
          "type": "boolean",
          "const": true
        },
        "execution_enabled": {
          "type": "boolean",
          "const": false
        },
        "approval_authority": {
          "type": "string"
        },
        "blocked_capabilities": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
