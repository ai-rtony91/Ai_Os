{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/aios/improvement_loop/TRACE_EVENT.schema.json",
  "title": "AI_OS Improvement Loop Trace Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "trace_id",
    "mode",
    "local_fixture_only",
    "event_type",
    "packet_id",
    "branch",
    "expected_worktree",
    "actual_worktree",
    "result",
    "lesson",
    "safety_flags"
  ],
  "properties": {
    "trace_id": { "type": "string" },
    "mode": { "type": "string", "enum": ["DRY_RUN"] },
    "local_fixture_only": { "type": "boolean", "const": true },
    "event_type": { "type": "string" },
    "packet_id": { "type": "string" },
    "branch": { "type": "string" },
    "expected_worktree": { "type": "string" },
    "actual_worktree": { "type": "string" },
    "result": { "type": "string" },
    "lesson": { "type": "string" },
    "safety_flags": {
      "type": "object",
      "required": ["live_openai_api_call", "api_key_required", "network_required", "package_install_required", "live_trading_status", "broker_execution_status", "oanda_status"],
      "properties": {
        "live_openai_api_call": { "type": "boolean", "const": false },
        "api_key_required": { "type": "boolean", "const": false },
        "network_required": { "type": "boolean", "const": false },
        "package_install_required": { "type": "boolean", "const": false },
        "live_trading_status": { "type": "string", "const": "BLOCKED" },
        "broker_execution_status": { "type": "string", "const": "BLOCKED" },
        "oanda_status": { "type": "string", "const": "BLOCKED" }
      }
    }
  }
}
