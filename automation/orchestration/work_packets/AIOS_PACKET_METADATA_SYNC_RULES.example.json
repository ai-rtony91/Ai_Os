{
  "schema": "aios_packet_metadata_sync_rules.v1",
  "mode": "DRY_RUN_READ_ONLY",
  "checks": [
    {
      "field": "branch",
      "rule": "branch_sync_needed is true when packet.branch does not match git branch --show-current.",
      "recommended_action": "metadata_sync_recommended"
    },
    {
      "field": "worker",
      "rule": "worker_sync_needed is true when packet.worker_id and packet.assigned_worker are both missing, blank, UNKNOWN, or placeholders.",
      "recommended_action": "metadata_sync_recommended"
    },
    {
      "field": "lock.worker_id",
      "rule": "lock.worker_id placeholder drift is reported separately from packet worker metadata.",
      "recommended_action": "lock_metadata_review_recommended"
    }
  ],
  "stale_field_values": [
    "",
    "UNKNOWN",
    "WORKER_ID_PLACEHOLDER",
    "PACKET_ID_PLACEHOLDER",
    "TIMESTAMP_PLACEHOLDER"
  ],
  "blocked_actions": [
    "packet_edits",
    "lock_edits",
    "state_movement",
    "Sync_APPLY_script_creation",
    "git_add",
    "commit",
    "push",
    "delete",
    "dashboard_work",
    "broker_trading_execution",
    "scheduled_tasks",
    "startup_task_changes",
    "secrets"
  ],
  "future_apply_command_template": "powershell -ExecutionPolicy Bypass -File automation/orchestration/work_packets/Sync-AiOsPacketMetadata.APPLY.ps1 -PacketPath \"<packet_path>\" -SyncBranch -WorkerId \"<worker_id>\""
}
